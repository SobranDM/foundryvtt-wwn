    {
      "_id": "AsCHhlF4POAl6CYy",
      "name": "Continual Light (Cleric)",
      "type": "spell",
      "sort": 2200000,
      "flags": {
        "cf": null,
        "core": {
          "sourceId": "Compendium.wwn.ose-spells.iV7RzEGlyuglmUbP"
