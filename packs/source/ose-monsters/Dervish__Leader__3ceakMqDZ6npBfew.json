    {
      "_id": "7KuuyfS9v1LgmJ1H",
      "name": "Continual Light (Cleric)",
      "type": "power",
      "img": "systems/wwn/assets/icons/items/spell.png",
      "sort": 1600000,
      "flags": {
        "cf": null,
        "core": {
