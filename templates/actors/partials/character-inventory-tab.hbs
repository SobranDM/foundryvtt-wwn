<section class="inventory" data-base-size="310">
  <div class="inventory-all flex flex-row">
    <div class="inventory-left flex-3">
      <div>
        <li
          class="item-titles flex flex-row items-center bg-wwn-header-bg text-white border border-wwn-border-strong shadow-[0_0_5px_var(--wwn-border-strong)] text-center py-1 text-[13px] mt-[7px]">
          <div class="item-caret flex-[0_0_10px] mx-1 cursor-pointer" data-action="item-caret"><i
              class="fas fa-caret-down"></i></div>
          <div class="item-name grow text-left indent-2">{{localize "WWN.items.Weapons"}}</div>
          <div class="icon-row grow text-center">{{localize "WWN.items.enterTrait"}}</div>
          {{#if config.useTrauma}}
          <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center"
            data-tooltip="{{localize 'WWN.items.TraumaDieHint'}}">{{localize
            "WWN.items.TraumaDie"}}
          </div>
          {{/if}}
          <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center"
            data-tooltip="{{localize 'WWN.items.Charges'}}"><i class="fas fa-magic"></i></div>
          <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center"
            data-tooltip="{{localize 'WWN.items.Quantity'}}"><i class="fas fa-hashtag"></i></div>
          <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center"
            data-tooltip="{{localize 'WWN.items.Weight' }}"><i class="fas fa-weight-hanging"></i>
          </div>
          <div class="item-controls text-xs basis-[60px] grow-0 flex items-center justify-end gap-1 mr-1">
            <a class="item-control item-search hover:text-wwn-accent-bright" data-action="item-search"
              data-type="weapon" data-tooltip="{{localize 'WWN.Search'}}"><i class="fa fa-search"></i></a>
            <a class="item-control item-create hover:text-wwn-accent-bright" data-action="item-create"
              data-type="weapon" data-tooltip="{{localize 'WWN.Add'}}"><i class="fa fa-plus"></i></a>
          </div>
        </li>
        <ol class="item-list list-none m-0 p-0">
          {{#each owned.weapons as |item|}}
          {{#unless item.system.containerId}}
          <li class="item-entry odd:bg-transparent even:bg-wwn-row-alt">
            <div class="item flex flex-row items-center h-[26px] overflow-hidden text-[14px]"
              data-item-id="{{item.id}}">
              <div
                class="item-name item-rollable flex flex-row grow indent-2 text-left overflow-hidden items-center basis-[90px]"
                data-action="item-roll">
                <div class="item-image basis-[24px] h-[24px] grow-0 shrink-0 bg-contain bg-no-repeat"
                  style="background-image: url({{item.img}})"></div>
                <a>
                  <p title="{{item.name}}">
                    {{item.name~}}
                    {{#if item.system.damage}}
                    <span class="text-wwn-text-muted">({{item.system.damage}})</span>
                    {{/if}}
                  </p>
                </a>
              </div>
              <div class="icon-row flex flex-row items-center grow">
                {{#each item.system.tags as |tag|}}
                {{#if (getTagIcon tag.value)}}
                <img title="{{getTagDesc tag.value}}" src="{{getTagIcon tag.value}}" width="24" height="24" />
                {{/if}}
                {{/each}}
                {{#each item.system.tags as |tag|}}
                {{#unless (getTagIcon tag.value)}}
                <span title="{{tag.title}}">{{tag.value}}{{#unless @last}},{{/unless}}</span>
                {{/unless}}
                {{/each}}
              </div>
              {{#if ../config.useTrauma}}
              <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center"
                data-tooltip="{{localize 'WWN.items.TraumaDieHint'}}">
                {{#if item.system.trauma.die}}
                {{item.system.trauma.die}}/x{{item.system.trauma.rating}}
                {{/if}}
              </div>
              {{/if}}
              <div class="field-short charges text-xs basis-[45px] grow-0 text-center relative group/charges">
                {{#if item.system.charges.decrementOnAttack}}
                <input value="{{item.system.charges.value}}" type="number" disabled
                  class="charges-input w-full text-center text-xs" />
                <div
                  class="charges-reload-overlay absolute inset-0 flex items-center justify-center bg-black/30 opacity-0 group-hover/charges:opacity-100 transition-opacity duration-150 cursor-pointer">
                  <a class="item-control item-reload hover:text-wwn-accent-bright" data-item-id="{{item.id}}"
                    title="{{localize 'WWN.items.ReloadWeapon'}}">
                    <i class="fas fa-sync-alt"></i>
                  </a>
                </div>
                {{else}}
                <input value="{{item.system.charges.value}}" type="number" />
                {{/if}}
              </div>
              <div class="field-short quantity text-xs basis-[45px] grow-0 text-center">
                <input value="{{item.system.quantity}}" type="number" />
              </div>
              <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center">
                <input value="{{item.system.weight}}" type="number" readonly>
              </div>
              <div class="item-controls text-xs basis-[60px] grow-0 flex items-center justify-end gap-1 mr-1">
                {{#if ../owner}}
                <a class="item-control item-toggle {{#unless item.system.equipped}}item-unequipped opacity-25{{/unless}} hover:text-wwn-accent-bright"
                  data-action="item-toggle" title='{{localize "WWN.items.Equip"}}'>
                  <i class="fas fa-tshirt"></i>
                </a>
                <a class="item-control stow-toggle {{#unless item.system.stowed}}item-unstowed opacity-25{{/unless}} hover:text-wwn-accent-bright"
                  data-action="stow-toggle" title='{{localize "WWN.items.stowed"}}'>
                  <i class="fas fa-archive"></i>
                </a>
                <a class="item-control item-edit hover:text-wwn-accent-bright" data-action="item-edit"
                  title='{{localize "WWN.Edit"}}'><i class="fas fa-edit"></i></a>
                <a class="item-control item-delete hover:text-wwn-accent-bright" data-action="item-delete"
                  title='{{localize "WWN.Delete"}}'><i class="fas fa-trash"></i></a>
                <a class="item-control toggle-favorite hover:text-wwn-accent-bright" data-action="toggle-favorite"
                  title='{{#if (contains @root.favoriteItemIds item.id)}}{{localize "WWN.RemoveFavorite"}}{{else}}{{localize "WWN.AddFavorite"}}{{/if}}'><i class="{{#if (contains @root.favoriteItemIds item.id)}}fas fa-star text-wwn-accent-bright{{else}}far fa-star{{/if}}"></i></a>
                {{/if}}
              </div>
            </div>
          </li>
          {{/unless}}
          {{/each}}
        </ol>
      </div>
      <div>
        <li
          class="item-titles flex flex-row items-center bg-wwn-header-bg text-white border border-wwn-border-strong shadow-[0_0_5px_var(--wwn-border-strong)] text-center py-1 text-[13px] mt-[7px]">
          <div class="item-caret flex-[0_0_10px] mx-1 cursor-pointer" data-action="item-caret"><i
              class="fas fa-caret-down"></i></div>
          <div class="item-name grow text-left indent-2">{{localize "WWN.items.Armors"}}</div>
          <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center">{{localize
            "WWN.items.ArmorAAC"}}</div>
          <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center"
            title="{{localize 'WWN.items.ArmorBonusHint'}}">{{localize "WWN.items.ArmorBonus"}}
          </div>
          {{#if config.useTrauma}}
          <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center"
            title="{{localize 'WWN.items.TraumaModHint'}}">
            {{localize "WWN.items.TraumaMod"}}
          </div>
          {{/if}}
          <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center"
            title="{{localize 'WWN.items.Weight' }}"><i class="fas fa-weight-hanging"></i></div>
          <div class="item-controls text-xs basis-[60px] grow-0 flex items-center justify-end gap-1 mr-1">
            <a class="item-control item-search hover:text-wwn-accent-bright" data-action="item-search" data-type="armor"
              title="{{localize 'WWN.Search'}}"><i class="fa fa-search"></i></a>
            <a class="item-control item-create hover:text-wwn-accent-bright" data-action="item-create" data-type="armor"
              title="{{localize 'WWN.Add'}}"><i class="fa fa-plus"></i></a>
          </div>
        </li>
        <ol class="item-list list-none m-0 p-0">
          {{#each owned.armors as |item|}}
          {{#unless item.system.containerId}}
          <li class="item-entry odd:bg-transparent even:bg-wwn-row-alt">
            <div class="item flex flex-row items-center h-[26px] overflow-hidden text-[14px]"
              data-item-id="{{item.id}}">
              <div
                class="item-name item-rollable flex flex-row grow indent-2 text-left overflow-hidden items-center basis-[90px]"
                data-action="item-roll">
                <div class="item-image basis-[24px] h-[24px] grow-0 shrink-0 bg-contain bg-no-repeat"
                  style="background-image: url({{item.img}})"></div>
                <a>
                  <p class="m-0" title="{{item.name}}">
                    {{item.name~}}
                  </p>
                </a>
              </div>
              <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center">
                {{item.system.aac.value}}
              </div>
              <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center">
                {{item.system.aac.mod}}
              </div>
              {{#if ../config.useTrauma}}
              <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center"
                data-tooltip="{{localize 'WWN.items.TraumaModHint'}}">
                {{item.system.traumaMod}}
              </div>
              {{/if}}
              <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center">
                {{item.system.weight}}
              </div>
              <div class="item-controls text-xs basis-[60px] grow-0 flex items-center justify-end gap-1 mr-1">
                {{#if ../owner}}
                <a class="item-control item-toggle {{#unless item.system.equipped}}item-unequipped opacity-25{{/unless}} hover:text-wwn-accent-bright"
                  data-action="item-toggle" title='{{localize "WWN.items.Equip"}}'>
                  <i class="fas fa-tshirt"></i>
                </a>
                <a class="item-control stow-toggle {{#unless item.system.stowed}}item-unstowed opacity-25{{/unless}} hover:text-wwn-accent-bright"
                  data-action="stow-toggle" title='{{localize "WWN.items.stowed"}}'>
                  <i class="fas fa-archive"></i>
                </a>
                <a class="item-control item-edit hover:text-wwn-accent-bright" data-action="item-edit"
                  title='{{localize "WWN.Edit"}}'><i class="fas fa-edit"></i></a>
                <a class="item-control item-delete hover:text-wwn-accent-bright" data-action="item-delete"
                  title='{{localize "WWN.Delete"}}'><i class="fas fa-trash"></i></a>
                <a class="item-control toggle-favorite hover:text-wwn-accent-bright" data-action="toggle-favorite"
                  title='{{#if (contains @root.favoriteItemIds item.id)}}{{localize "WWN.RemoveFavorite"}}{{else}}{{localize "WWN.AddFavorite"}}{{/if}}'><i class="{{#if (contains @root.favoriteItemIds item.id)}}fas fa-star text-wwn-accent-bright{{else}}far fa-star{{/if}}"></i></a>
                {{/if}}
              </div>
            </div>
          </li>
          {{/unless}}
          {{/each}}
        </ol>
      </div>
      <div>
        {{!-- Consumable items --}}
        <li
          class="item-titles flex flex-row items-center bg-wwn-header-bg text-white border border-wwn-border-strong shadow-[0_0_5px_var(--wwn-border-strong)] text-center py-1 text-[13px] mt-[7px]">
          <div class="item-caret flex-[0_0_10px] mx-1 cursor-pointer" data-action="item-caret"><i
              class="fas fa-caret-down"></i></div>
          <div class="item-name grow text-left indent-2">{{localize "WWN.category.consumables"}}</div>
          <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center"
            title="{{localize 'WWN.items.Charges'}}"><i class="fas fa-magic"></i></div>
          <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center"
            title="{{localize 'WWN.items.Weight' }}"><i class="fas fa-weight-hanging"></i></div>
          <div class="item-controls text-xs basis-[60px] grow-0 flex items-center justify-end gap-1 mr-1">
            <a class="item-control item-create hover:text-wwn-accent-bright" data-action="item-create" data-type="item"
              data-consumable="true" title="{{localize 'WWN.Add'}}"><i class="fa fa-plus"></i></a>
          </div>
        </li>
        <ol class="item-list list-none m-0 p-0">
          {{#each owned.items as |item|}}
          {{#if (evalOr item.system.charges.value item.system.charges.max)}}
          {{#unless item.system.containerId}}
          <li class="item-entry odd:bg-transparent even:bg-wwn-row-alt">
            <div class="item flex flex-row items-center h-[26px] overflow-hidden text-[14px]"
              data-item-id="{{item.id}}">
              <div
                class="item-name item-rollable flex flex-row grow indent-2 text-left overflow-hidden items-center basis-[90px]"
                data-action="item-roll">
                <div class="item-image basis-[24px] h-[24px] grow-0 shrink-0 bg-contain bg-no-repeat"
                  style="background-image: url({{item.img}})"></div>
                <a>
                  <p class="m-0" title="{{item.name}}">
                    {{item.name~}}
                  </p>
                </a>
              </div>
              <div class="field-short charges text-xs basis-[45px] grow-0 text-center relative group/charges">
                {{#if item.system.charges.decrementOnAttack}}
                <input value="{{item.system.charges.value}}" type="number" disabled
                  class="charges-input w-full text-center text-xs" />
                <div
                  class="charges-reload-overlay absolute inset-0 flex items-center justify-center bg-black/30 opacity-0 group-hover/charges:opacity-100 transition-opacity duration-150 cursor-pointer">
                  <a class="item-control item-reload hover:text-wwn-accent-bright" data-item-id="{{item.id}}"
                    title="{{localize 'WWN.items.ReloadWeapon'}}">
                    <i class="fas fa-sync-alt"></i>
                  </a>
                </div>
                {{else}}
                <input value="{{item.system.charges.value}}" type="number" />
                {{/if}}
              </div>
              <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center">
                <input value="{{item.system.weight}}" type="number" readonly />
              </div>
              <div class="item-controls text-xs basis-[60px] grow-0 flex items-center justify-end gap-1 mr-1">
                {{#if ../owner}}
                <a class="item-control item-toggle {{#unless item.system.equipped}}item-unequipped opacity-25{{/unless}} hover:text-wwn-accent-bright"
                  data-action="item-toggle" title='{{localize "WWN.items.Equip"}}'>
                  <i class="fas fa-tshirt"></i>
                </a>
                <a class="item-control stow-toggle {{#unless item.system.stowed}}item-unstowed opacity-25{{/unless}} hover:text-wwn-accent-bright"
                  data-action="stow-toggle" title='{{localize "WWN.items.stowed"}}'>
                  <i class="fas fa-archive"></i>
                </a>
                <a class="item-control item-edit hover:text-wwn-accent-bright" data-action="item-edit"
                  title='{{localize "WWN.Edit"}}'><i class="fas fa-edit"></i></a>
                <a class="item-control item-delete hover:text-wwn-accent-bright" data-action="item-delete"
                  title='{{localize "WWN.Delete"}}'><i class="fas fa-trash"></i></a>
                <a class="item-control toggle-favorite hover:text-wwn-accent-bright" data-action="toggle-favorite"
                  title='{{#if (contains @root.favoriteItemIds item.id)}}{{localize "WWN.RemoveFavorite"}}{{else}}{{localize "WWN.AddFavorite"}}{{/if}}'><i class="{{#if (contains @root.favoriteItemIds item.id)}}fas fa-star text-wwn-accent-bright{{else}}far fa-star{{/if}}"></i></a>
                {{/if}}
              </div>
            </div>
          </li>
          {{/unless}}
          {{/if}}
          {{/each}}
        </ol>
      </div>

      <div>
        {{!-- Misc items --}}
        <li
          class="item-titles flex flex-row items-center bg-wwn-header-bg text-white border border-wwn-border-strong shadow-[0_0_5px_var(--wwn-border-strong)] text-center py-1 text-[13px] mt-[7px]">
          <div class="item-caret flex-[0_0_10px] mx-1 cursor-pointer" data-action="item-caret"><i
              class="fas fa-caret-down"></i></div>
          <div class="item-name grow text-left indent-2">{{localize "WWN.items.Misc"}}</div>
          <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center"
            title="{{localize 'WWN.items.Quantity'}}"><i class="fas fa-hashtag"></i></div>
          <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center"
            title="{{localize 'WWN.items.Weight' }}"><i class="fas fa-weight-hanging"></i></div>
          <div class="item-controls text-xs basis-[60px] grow-0 flex items-center justify-end gap-1 mr-1">
            <a class="item-control item-search hover:text-wwn-accent-bright" data-action="item-search" data-type="item"
              title="{{localize 'WWN.Search'}}"><i class="fa fa-search"></i></a>
            <a class="item-control item-create hover:text-wwn-accent-bright" data-action="item-create" data-type="item"
              title="{{localize 'WWN.Add'}}"><i class="fa fa-plus"></i></a>
          </div>
        </li>
        <ol class="item-list list-none m-0 p-0">
          {{#each owned.items as |item|}}
          {{#unless (evalOr (evalOr item.system.charges.value item.system.personal) item.system.treasure) }}
          {{#unless item.system.containerId}}
          <li class="item-entry odd:bg-transparent even:bg-wwn-row-alt">
            <div class="item flex flex-row items-center h-[26px] overflow-hidden text-[14px]"
              data-item-id="{{item.id}}">
              <div
                class="item-name item-rollable flex flex-row grow indent-2 text-left overflow-hidden items-center basis-[90px]"
                data-action="item-roll">
                <div class="item-image basis-[24px] h-[24px] grow-0 shrink-0 bg-contain bg-no-repeat"
                  style="background-image: url({{item.img}})"></div>
                {{#if item.system.container.isContainer}}
                <div class="container-arrow cursor-pointer mr-1 transition-transform duration-150">
                  <i class="fas {{#if item.system.container.isOpen}}fa-caret-down{{else}}fa-caret-right{{/if}}"
                    title="Toggle Contents"></i>
                </div>
                {{/if}}
                <a>
                  <p class="m-0" title="{{item.name}}">
                    {{item.name~}}
                  </p>
                </a>
              </div>
              <div class="field-short quantity text-xs basis-[45px] grow-0 text-center">
                <input value="{{item.system.quantity}}" type="number" placeholder="0" />
              </div>
              <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center">
                <input value="{{item.system.weight}}" type="number" readonly />
              </div>
              <div class="item-controls text-xs basis-[60px] grow-0 flex items-center justify-end gap-1 mr-1">
                {{#if ../owner}}
                <a class="item-control item-toggle {{#unless item.system.equipped}}item-unequipped opacity-25{{/unless}} hover:text-wwn-accent-bright"
                  data-action="item-toggle" title='{{localize "WWN.items.Equip"}}'>
                  <i class="fas fa-tshirt"></i>
                </a>
                <a class="item-control stow-toggle {{#unless item.system.stowed}}item-unstowed opacity-25{{/unless}} hover:text-wwn-accent-bright"
                  data-action="stow-toggle" title='{{localize "WWN.items.stowed"}}'>
                  <i class="fas fa-archive"></i>
                </a>
                <a class="item-control item-edit hover:text-wwn-accent-bright" data-action="item-edit"
                  title='{{localize "WWN.Edit"}}'><i class="fas fa-edit"></i></a>
                <a class="item-control item-delete hover:text-wwn-accent-bright" data-action="item-delete"
                  title='{{localize "WWN.Delete"}}'><i class="fas fa-trash"></i></a>
                <a class="item-control toggle-favorite hover:text-wwn-accent-bright" data-action="toggle-favorite"
                  title='{{#if (contains @root.favoriteItemIds item.id)}}{{localize "WWN.RemoveFavorite"}}{{else}}{{localize "WWN.AddFavorite"}}{{/if}}'><i class="{{#if (contains @root.favoriteItemIds item.id)}}fas fa-star text-wwn-accent-bright{{else}}far fa-star{{/if}}"></i></a>
                {{/if}}
              </div>
            </div>
            {{#if item.system.container.isContainer}}
            <ol class="item-list container-items list-none m-0 p-0 ml-5 border-l-2 border-wwn-border-light"
              style="display: {{#if item.system.container.isOpen}}block{{else}}none{{/if}};">

              {{#each ../owned.weapons as |weapon|}}
              {{#if (eq weapon.system.containerId item.id)}}
              <li class="item-entry container-item odd:bg-transparent even:bg-wwn-row-alt">
                <div class="item flex flex-row items-center h-[26px] overflow-hidden text-[14px]"
                  data-item-id="{{weapon.id}}">
                  <div
                    class="item-name item-rollable flex flex-row grow indent-2 text-left overflow-hidden items-center basis-[90px]"
                    data-action="item-roll">
                    <div class="item-image basis-[24px] h-[24px] grow-0 shrink-0 bg-contain bg-no-repeat"
                      style="background-image: url({{weapon.img}})"></div>
                    <div class="container-spacer"></div>
                    <a>
                      <p class="m-0" title="{{weapon.name}}">
                        {{weapon.name~}}
                      </p>
                    </a>
                  </div>
                  <div class="field-short quantity text-xs basis-[45px] grow-0 text-center">
                    <input value="{{weapon.system.quantity}}" type="number" placeholder="0" />
                  </div>
                  <div class="field-short text-xs basis-[45px] grow-0 text-center flex items-center justify-center">
                    <input value="{{weapon.system.weight}}" type="number" readonly />
                  </div>
                  <div class="item-controls text-xs basis-[60px] grow-0 flex items-center justify-end gap-1 mr-1">
                    {{#if ../../owner}}
                    <a class="item-control item-edit hover:text-wwn-accent-bright" data-action="item-edit"
                      title='{{localize "WWN.Edit"}}'><i class="fas fa-edit"></i></a>
                    <a class="item-control item-delete hover:text-wwn-accent-bright" data-action="item-delete"
                      title='{{localize "WWN.Delete"}}'><i class="fas fa-trash"></i></a>
                    {{/if}}
                  </div>
                </div>
              </li>
              {{/if}}
              {{/each}}

              {{#each ../owned.armors as |armor|}}
              {{#if (eq armor.system.containerId item.id)}}
              <li class="item-entry container-item odd:bg-transparent even:bg-wwn-row-alt">
                <div class="item flex flex-row items-center h-[26px] overflow-hidden text-[14px]"
                  data-item-id="{{armor.id}}">
                  <div
                    class="item-name item-rollable flex flex-row grow indent-2 text-left overflow-hidden items-center basis-[90px]"
                    data-action="item-roll">
                    <div class="item-image basis-[24px] h-[24px] grow-0 shrink-0 bg-contain bg-no-repeat"
                      style="background-image: url({{armor.img}})"></div>
                    <div class="container-spacer"></div>
                    <a>
                      <p class="m-0" title="{{armor.name}}">
                        {{armor.name~}}
                      </p>
                    </a>
                  </div>
                  <div class="field-short quantity text-xs basis-[45px] grow-0 text-center">
