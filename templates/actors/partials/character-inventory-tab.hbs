              data-dtype="Number" disabled class="w-[3.5em] text-center text-xs" />
            <span class="text-wwn-text-muted">/</span>
            <input name="system.encumbrance.readied.max" type="number" value="{{system.encumbrance.readied.max}}"
              data-dtype="Number" disabled class="w-[3.5em] text-center text-xs" />
          </div>
        </div>
        <div class="flex flex-row items-center h-[26px] border-b border-wwn-border-light bg-wwn-row-alt text-[12px]">
          <label class="w-[52px] shrink-0 text-center text-wwn-text-muted text-[11px]">{{localize
            'WWN.items.stowed'}}</label>
          <div class="flex-1 flex items-center justify-center gap-0.5">
            <input name="system.encumbrance.stowed.value" type="number" value="{{system.encumbrance.stowed.value}}"
              data-dtype="Number" disabled class="w-[3.5em] text-center text-xs" />
            <span class="text-wwn-text-muted">/</span>
            <input name="system.encumbrance.stowed.max" type="number" value="{{system.encumbrance.stowed.max}}"
              data-dtype="Number" disabled class="w-[3.5em] text-center text-xs" />
          </div>
        </div>
      </div>
      {{!-- Resources (rations, torches, oil) --}}
      <div
        class="item-titles flex items-center justify-center bg-wwn-header-bg text-white border border-wwn-border-strong text-center py-1 text-[13px] mt-2">
        <label>{{localize 'WWN.resources.consumable'}}</label>
      </div>
      <div class="flex flex-col readied-group">
        <div class="flex flex-row items-center h-[26px] border-b border-wwn-border-light text-[12px]">
          <label class="w-[52px] shrink-0 text-center text-wwn-text-muted text-[11px]" title="{{localize 'WWN.resources.rations'}}">{{localize 'WWN.resources.rations'}}</label>
          <input class="flex-1 text-center text-xs" name="system.details.resources.rations" type="number"
            value="{{system.details.resources.rations}}" data-dtype="Number" placeholder="0" />
        </div>
        <div class="flex flex-row items-center h-[26px] border-b border-wwn-border-light bg-wwn-row-alt text-[12px]">
          <label class="w-[52px] shrink-0 text-center text-wwn-text-muted text-[11px]" title="{{localize 'WWN.resources.torches'}}">{{localize 'WWN.resources.torches'}}</label>
          <input class="flex-1 text-center text-xs" name="system.details.resources.torches" type="number"
            value="{{system.details.resources.torches}}" data-dtype="Number" placeholder="0" />
        </div>
        <div class="flex flex-row items-center h-[26px] border-b border-wwn-border-light text-[12px]">
          <label class="w-[52px] shrink-0 text-center text-wwn-text-muted text-[11px]" title="{{localize 'WWN.resources.oil'}}">{{localize 'WWN.resources.oil'}}</label>
          <input class="flex-1 text-center text-xs" name="system.details.resources.oil" type="number"
            value="{{system.details.resources.oil}}" data-dtype="Number" placeholder="0" />
        </div>
      </div>
      {{!-- Currency --}}
      <div
        class="item-titles flex items-center justify-center bg-wwn-header-bg text-white border border-wwn-border-strong text-center py-1 text-[13px] mt-2">
        <label class="flex items-center gap-1">
          {{localize 'WWN.items.Currency'}}
          <a data-action="currency-adjust" title="{{localize 'WWN.items.adjustCurrency'}}"
            class="currency-adjust hover:text-wwn-accent-bright">
            <i class="fas fa-balance-scale"></i>
          </a>
        </label>
      </div>
      <div class="flex flex-col currency-group">
        <div class="flex flex-row items-center h-[26px] border-b border-wwn-border-light text-[12px]">
          <label class="w-[40px] shrink-0 text-center text-[11px] text-wwn-text-muted font-medium"
            title="{{localize 'WWN.items.CP.long'}}">CP</label>
          <input class="flex-1 text-center text-xs" name="system.currency.cp" type="number"
            value="{{system.currency.cp}}" data-dtype="Number" placeholder="0" />
        </div>
        <div class="flex flex-row items-center h-[26px] border-b border-wwn-border-light bg-wwn-row-alt text-[12px]">
          <label class="w-[40px] shrink-0 text-center text-[11px] text-wwn-text-muted font-medium"
            title="{{localize 'WWN.items.SP.long'}}">SP</label>
          <input class="flex-1 text-center text-xs" name="system.currency.sp" type="number"
            value="{{system.currency.sp}}" data-dtype="Number" placeholder="0" />
        </div>
        {{#if (eq config.currencyTypes "currencybx")}}
        <div class="flex flex-row items-center h-[26px] border-b border-wwn-border-light text-[12px]">
          <label class="w-[40px] shrink-0 text-center text-[11px] text-wwn-text-muted font-medium"
            title="{{localize 'WWN.items.EP.long'}}">EP</label>
          <input class="flex-1 text-center text-xs" name="system.currency.ep" type="number"
            value="{{system.currency.ep}}" data-dtype="Number" placeholder="0" />
        </div>
        {{/if}}
        <div
          class="flex flex-row items-center h-[26px] border-b border-wwn-border-light {{#if (eq config.currencyTypes "
          currencybx")}}bg-wwn-row-alt{{/if}} text-[12px]">
          <label class="w-[40px] shrink-0 text-center text-[11px] text-wwn-text-muted font-medium"
            title="{{localize 'WWN.items.GP.long'}}">GP</label>
          <input class="flex-1 text-center text-xs" name="system.currency.gp" type="number"
            value="{{system.currency.gp}}" data-dtype="Number" placeholder="0" />
        </div>
        {{#if (eq config.currencyTypes "currencybx")}}
        <div class="flex flex-row items-center h-[26px] border-b border-wwn-border-light text-[12px]">
          <label class="w-[40px] shrink-0 text-center text-[11px] text-wwn-text-muted font-medium"
            title="{{localize 'WWN.items.PP.long'}}">PP</label>
          <input class="flex-1 text-center text-xs" name="system.currency.pp" type="number"
            value="{{system.currency.pp}}" data-dtype="Number" placeholder="0" />
        </div>
        {{/if}}
        <div class="flex flex-row items-center h-[26px] border-b border-wwn-border-light bg-wwn-row-alt text-[12px]">
          <label class="w-[40px] shrink-0 text-center text-[11px] text-wwn-text-muted font-medium"
            title="Personal Treasure">Pers</label>
          <input class="flex-1 text-center text-xs" name="system.personalTreasure" title="Personal Treasure"
            type="number" value="{{system.personalTreasure}}" data-dtype="Number" disabled />
        </div>
        <div class="flex flex-row items-center h-[26px] border-b border-wwn-border-light text-[12px]">
          <label class="w-[40px] shrink-0 text-center text-[11px] text-wwn-text-muted font-medium">Bank</label>
          <input class="flex-1 text-center text-xs" name="system.currency.bank" type="number"
            value="{{system.currency.bank}}" data-dtype="Number" placeholder="0" />
        </div>
        <div class="flex flex-row items-center h-[26px] border-b border-wwn-border bg-wwn-row-alt text-[12px]">
          <label class="w-[40px] shrink-0 text-center text-[11px] text-wwn-text-muted font-medium"
            title="Total Currency">Total</label>
          <input class="flex-1 text-center text-xs" name="system.currency.total" type="number"
            value="{{system.currency.total}}" data-dtype="Number" disabled />
        </div>
        <div class="flex flex-row items-center h-[26px] border-b border-wwn-border-light text-[12px]">
          <label class="w-[40px] shrink-0 text-center text-[11px] text-wwn-text-muted font-medium"
            title="{{localize 'WWN.items.TreasureSP'}}">Treas</label>
          <input class="flex-1 text-center text-xs" name="system.treasure" type="number" value="{{system.treasure}}"
            data-dtype="Number" disabled />
        </div>
        <div class="flex flex-row items-center h-[26px] border-b border-wwn-border-light bg-wwn-row-alt text-[12px]">
          <label class="w-[40px] shrink-0 text-center text-[11px] text-wwn-text-muted font-medium" title="{{localize 'WWN.items.currencyShare'}}">Share %</label>
          <input class="flex-1 text-center text-xs" name="system.currency.share" type="number"
            value="{{system.currency.share}}" data-dtype="Number" placeholder="100" min="0" max="100" />
        </div>
      </div>
    </div>
  </div>
</section>