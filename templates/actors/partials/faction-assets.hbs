<div class="inventory" role="table">
  <!-- table-->
  <div class="item-titles flex-table header flex flex-row bg-wwn-header-bg text-white border border-wwn-border-strong text-center py-1 text-[13px]" role="rowgroup">
    <div class="item-caret"><i class="fas fa-caret-down"></i></div>
    <div class="item-name flex flex-row flex-1 min-w-0 indent-2 text-left" role="columnheader">{{ name }} Assets </div>
    <div class="faction-field flex flex-row flex-none basis-[50px] text-xs text-center" role="columnheader"> {{ localize 'WWN.faction.rating' }} </div>
    <div class="faction-field flex flex-row flex-none basis-[50px] text-xs text-center" role="columnheader"> {{ localize 'WWN.faction.hp' }} </div>
    <div class="faction-field-wide flex flex-row flex-none basis-[90px] text-xs text-left" role="columnheader"> {{ localize 'WWN.faction.location' }} </div>
    <div class="faction-field-wide damage flex flex-row flex-none basis-[90px] text-xs text-left" role="columnheader"> {{ localize 'WWN.faction.attackDamage' }} </div>
    <div class="faction-field counter flex flex-row flex-none basis-[50px] text-xs text-center" role="columnheader"> {{ localize 'WWN.faction.counter' }} </div>
    <!-- <div class="field-short flex flex-row " role="columnheader"> {{ localize 'WWN.faction.note' }} </div> -->

    <div class="item-controls med-cell flex flex-row flex-shrink text-right text-xs basis-[60px]" role="columnheader">
      <a class="item-control add-base text-gray-100 hover:text-green-400 transition-colors"
        title="{{localize 'WWN.Add'}}" data-asset-type="{{ assetType }}" data-asset-name="{{ name }}">
        <i class="fas fa-home"></i>
      </a>
      <a class="item-control asset-create text-gray-100 hover:text-green-400 transition-colors"
        title="{{localize 'WWN.Add'}}" data-asset-type="{{ assetType }}" data-asset-name="{{ name }}">
        <i class="fas fa-plus"></i>
      </a>
    </div>
  </div>
  <ol class="item-list">
    {{#each assets as |item id|}}
    <li class="item-entry odd:bg-transparent even:bg-wwn-row-alt">
      <div class="item flex flex-row leading-[30px] h-[30px] overflow-hidden" role="rowgroup" data-item-id="{{item.id}}">
        <div class="item-name item-click item-rollable flex flex-row faction-name flex-1 min-w-0 indent-2 text-left overflow-hidden"><!---->
          <div class="item-image" style="background-image: url({{item.img}})"></div>
          <a>
            <p class="m-0" title="{{item.system.description}}">
              {{item.name~}}
              {{#if item.system.baseOfInfluence}}
              <i class="fas fa-home" style="color: rgba(0, 0, 0, 0.2);"></i>
              {{/if}}
            </p>
          </a>
        </div>
        <div class="faction-field flex-none basis-[50px] text-xs text-center" role="cell">
          {{ item.system.rating }}
        </div>
        <div class="faction-field flex-none basis-[50px] text-xs text-center" role="cell">
          {{ item.system.health.value }}/{{ item.system.health.max }}
        </div>
        <div class="faction-field-wide flex-none basis-[90px] text-xs text-left" role="cell">
          <input type="text" value="{{ item.system.location }}" />
        </div>
        <div class="faction-field-wide damage flex-none basis-[90px] text-xs text-left" role="cell">
          {{#if item.system.attackDamage}}
          {{firstLetter item.system.attackSource }} vs {{firstLetter item.system.attackTarget }} /
          {{ item.system.attackDamage }}
          {{/if}}
        </div>
        <div class="faction-field counter flex-none basis-[50px] text-xs text-center" role="cell">
          {{ item.system.counter }}
        </div>
        <div class="item-controls med-cell pr-1 text-right flex-shrink flex flex-row text-xs basis-[60px]" role="cell">
          {{!-- <a class="item-control item-fix text-gray-600 hover:text-purple-800 transition-colors"
            title='{{localize "WWN.Fix"}}'>
            <i class="fas fa-tools"></i></a> --}}
          <a class="item-control asset-toggle-unusable hover:text-wwn-accent-bright {{#unless item.system.unusable}}item-off opacity-25{{/unless}}"
            title='{{localize "WWN.Break"}}'>
            <i class="fas fa-heart-broken"></i>
          </a>
          <a class="item-control asset-toggle-stealthed hover:text-wwn-accent-bright {{#unless item.system.stealthed}}item-off opacity-25{{/unless}}"
            title='{{localize "WWN.faction.stealthed"}}'>
            <i class="fas fa-user-ninja"></i>
          </a>
          <a class="item-control item-edit text-gray-600 hover:text-purple-800 transition-colors"
            title='{{localize "WWN.Edit"}}'>
            <i class="fas fa-edit"></i></a>
          <a class="item-control item-delete text-gray-600 hover:text-red-600 transition-colors"
            title='{{localize "WWN.Delete"}}'>
            <i class="fas fa-trash"></i></a>
        </div>
      </div>
    </li>
    {{/each}}
  </ol>
</div>
