<section class="inventory" data-base-size="310">
  <div class="inventory-all flex flex-row">
    <div class="inventory-left flex-[3]">
      <div>
        {{!-- Crew list --}}
        <li class="item-titles flex flex-row bg-wwn-header-bg text-white border border-wwn-border-strong text-center py-1 text-[13px]">
          <div class="item-caret" data-action="item-caret"><i class="fas fa-caret-down"></i></div>
          <div class="item-name flex-1 min-w-0 indent-2 text-left">Crew on Board</div>
          <div class="field-long basis-[80px] text-center text-xs" data-tooltip="{{localize 'WWN.items.crew.cost'}}">{{data.treasure}} <i class="fas fa-circle"></i></div>
          <div class="field-short text-xs basis-[45px] text-center" data-tooltip="{{localize 'WWN.items.crew.quantity'}}"><i class="fas fa-hashtag"></i></div>
          <div class="field-short text-xs basis-[45px] text-center" data-tooltip="{{localize 'WWN.items.crew.strengthIndividual' }}"><i class="fa-solid fa-dumbbell"></i>
          </div>
          <div class="item-controls text-xs basis-[60px] text-right">
            <a class="item-control crew-create hover:text-wwn-accent-bright" data-action="item-create" data-type="crewmember" data-treasure="false"
              data-tooltip="{{localize 'WWN.Add'}}"><i class="fa fa-plus"></i></a>
          </div>
        </li>
        <ol class="item-list">
          {{#each owned.crewmembers as |item|}}
          <li class="item-entry odd:bg-transparent even:bg-wwn-row-alt">
            <div class="item flex flex-row leading-[30px] h-[30px] overflow-hidden" data-item-id="{{item.id}}">
              <div class="item-name item-rollable flex flex-row flex-1 min-w-0 indent-2 text-left overflow-hidden">
                <div class="item-image" style="background-image: url({{item.img}})"></div>
                <a>
                  {{#if item.system.ispc}}
                  <p class="m-0" data-tooltip="{{item.name}}">
                    <strong>{{item.name~}}</strong>
                  </p>
                  {{else}}
                  <p class="m-0" data-tooltip="{{item.name}}">
                    {{item.name~}}
                  </p>
                  {{/if}}                  
                </a>
              </div>
              {{#if (eq item.system.ispc false)}}
                <div class="field-long basis-[80px] text-center text-xs" data-tooltip="{{localize 'WWN.items.crew.cost'}}">
                  {{item.system.cost}}
                </div>
              {{/if}}
              <div class="field-short quantity text-xs basis-[45px] text-center" data-tooltip="{{localize 'WWN.items.crew.quantity'}}">
                <input value="{{item.system.quantity}}" type="number" />
              </div>
              <div class="field-short text-xs basis-[45px] text-center" data-tooltip="{{localize 'WWN.items.crew.strength'}}" type="number">
                {{item.system.strength}}
              </div>
              <div class="item-controls text-xs basis-[60px] text-right">
                {{#if ../owner}}
                <a class="item-control item-edit hover:text-wwn-accent-bright" data-action="item-edit" data-tooltip='{{localize "WWN.Edit"}}'><i
                    class="fas fa-edit"></i></a>
                <a class="item-control item-delete hover:text-wwn-accent-bright" data-action="item-delete" data-tooltip='{{localize "WWN.Delete"}}'><i
                    class="fas fa-trash"></i></a>
                {{/if}}
              </div>
            </div>
          </li>
          {{/each}}
        </ol>
      </div>
    </div>
    <div class="inventory-right">
      <div class="item-titles flex flex-row bg-wwn-header-bg text-white border border-wwn-border-strong text-center py-1 text-[13px]">
        <label>{{localize 'WWN.items.crew.strengthTotal'}}</label>
      </div>
      <div class="readied-group">
        <div class="flex flex-row readied-subgroup items-center gap-1">
          <label class="readied-header text-wwn-panel-title px-1 py-0.5 border border-wwn-border-strong bg-wwn-header-bg text-center h-[30px] leading-[26px] text-[13px]">{{localize 'WWN.items.crew.strengthOfShip'}}</label>
          <div class="readied border border-wwn-border-strong shadow-[0_0_2px_var(--wwn-border)] flex h-[30px] items-center">
            <input name="system.details.crew.totalstrength" type="number" value="{{system.details.crew.totalstrength}}"
              data-dtype="Number" disabled />
          </div>
        </div>
        <div class="flex flex-row readied-subgroup items-center gap-1">
          <label class="readied-header text-wwn-panel-title px-1 py-0.5 border border-wwn-border-strong bg-wwn-header-bg text-center h-[30px] leading-[26px] text-[13px]">{{localize 'WWN.items.crew.strengthOfPCs'}}</label>
          <div class="readied border border-wwn-border-strong shadow-[0_0_2px_var(--wwn-border)] flex h-[30px] items-center">
            <input name="system.details.crew.pcstrength" type="number" value="{{system.details.crew.pcstrength}}"
              data-dtype="Number" disabled />
          </div>
        </div>
      </div>
      <div class="item-titles flex flex-row bg-wwn-header-bg text-white border border-wwn-border-strong text-center py-1 text-[13px]">
        <label>
          {{localize 'WWN.items.crew.costTotal'}}
          <a data-action="pay-crew" title="{{localize 'WWN.items.adjustCurrency'}}" class="currency-adjust" disabled>
            <i class="fas fa-balance-scale"></i>
          </a>
        </label>
      </div>
      <div class="flex flex-row currency-group flex-wrap">
        <div class="flex flex-row currency-subgroup items-center gap-1">
          <label class="currency-header text-wwn-panel-title px-1 py-0.5 border border-wwn-border-strong bg-wwn-header-bg text-center h-[30px] leading-[26px] text-[13px]" title="{{localize 'WWN.items.crew.costTotal'}}">{{localize
            'WWN.items.crew.costShort'}}</label>
          <input class="currency border border-wwn-border-strong shadow-[0_0_2px_var(--wwn-border)] h-[30px] text-center text-xs w-full" name="system.details.crew.totalcost" type="number" value="{{system.details.crew.totalcost}}"
            data-dtype="Number" placeholder="0" disabled />
        </div>
      </div>
    </div>
  </div>
</section>
