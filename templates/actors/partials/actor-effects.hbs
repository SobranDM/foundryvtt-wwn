<ol class="items-list effects-list list-none m-0 p-2">
  {{#each effects as |section sid|}}
  <li class="items-header flex flex-row items-center bg-wwn-header-bg text-white border border-wwn-border-strong rounded-t py-1 text-[13px] mt-2 first:mt-0" data-effect-type="{{section.type}}">
    <h3 class="item-name effect-name flex-1 min-w-0 indent-2 text-left text-sm m-0">{{localize section.label}}</h3>
    <div class="effect-source basis-[80px] text-center text-xs">Source</div>
    <div class="effect-source basis-[80px] text-center text-xs">Duration</div>
    <div class="item-controls effect-controls basis-[60px] text-right text-xs mr-1">
      <a class="effect-control hover:text-wwn-accent-bright" data-action="create" title="{{localize 'WWN.EffectCreate'}}">
        <i class="fas fa-plus"></i> {{localize "WWN.Add"}}
      </a>
    </div>
  </li>

  <ol class="item-list list-none m-0 border border-wwn-border border-t-0 rounded-b overflow-hidden">
    {{#each section.effects as |effect|}}
    <li class="item effect flex flex-row items-center min-h-[30px] overflow-hidden odd:bg-transparent even:bg-wwn-row-alt border-b border-wwn-border-light last:border-b-0" data-effect-id="{{effect.id}}">
      <div class="item-name effect-name flex-1 min-w-0 indent-2 text-left overflow-hidden text-sm truncate">
        {{effect.name}}
      </div>
      <div class="effect-source basis-[80px] text-center text-xs text-wwn-text-muted">{{effect.sourceName}}</div>
      <div class="effect-duration basis-[80px] text-center text-xs text-wwn-text-muted">{{effect.duration.label}}</div>
      <div class="item-controls effect-controls basis-[60px] text-right text-xs mr-1">
        <a class="effect-control hover:text-wwn-accent-bright" data-action="toggle" title="{{localize 'WWN.EffectToggle'}}">
          <i class="fas {{#if effect.disabled}}fa-check{{else}}fa-times{{/if}}"></i>
        </a>
        <a class="effect-control hover:text-wwn-accent-bright" data-action="edit" title="{{localize 'WWN.EffectEdit'}}">
          <i class="fas fa-edit"></i>
        </a>
        <a class="effect-control hover:text-wwn-accent-bright" data-action="delete" title="{{localize 'WWN.EffectDelete'}}">
          <i class="fas fa-trash"></i>
        </a>
      </div>
    </li>
    {{/each}}
  </ol>
  {{/each}}
</ol>
