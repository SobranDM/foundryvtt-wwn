<section class="attributes-tab">
    <section class="flex flex-row gap-2">
        <div class="flex flex-row gap-2 flex-1">
            <ul class="attributes flex flex-col gap-1 flex-1">
                <li class="health">
                    <h4 class="bg-wwn-header-bg text-wwn-panel-title text-center p-0.5 border border-wwn-border-strong" title="{{localize 'WWN.Health'}}">{{ localize "WWN.HealthShort"
                        }}
                        <a class="hp-roll" data-action="hp-roll"><i class="fas fa-dice"></i></a>
                    </h4>
                    <div class="flex flex-row text-center p-1">
                        <input name="system.hp.value" type="number" value="{{system.hp.value}}" data-dtype="Number"
                            placeholder="0" />
                        <span class="sep"> / </span>
                        <input name="system.hp.max" type="text" value="{{system.hp.max}}" data-dtype="Number"
                            placeholder="0" />
                    </div>
                </li>
                <li class="morale-check">
                    <h4 class="bg-wwn-header-bg text-wwn-panel-title text-center p-0.5 border border-wwn-border-strong"><a>{{ localize "WWN.details.morale" }}</a>
                    </h4>
                    <div class="text-center p-1">
                        <input name="system.details.morale" type="number" value="{{system.details.morale}}" placeholder="0"
                            data-dtype="Number" />
                    </div>
                </li>
                <li class="instinct-check">
                    <h4 class="bg-wwn-header-bg text-wwn-panel-title text-center p-0.5 border border-wwn-border-strong"><a>{{ localize "WWN.details.instinct" }}</a>
                    </h4>
                    <div class="text-center p-1">
                        <input name="system.details.instinct" type="number" value="{{system.details.instinct}}"
                            placeholder="0" data-dtype="Number" />
                    </div>
                </li>
            </ul>
            <ul class="attributes flex flex-col gap-1 flex-1">
                <li>
                    <h4 class="bg-wwn-header-bg text-wwn-panel-title text-center p-0.5 border border-wwn-border-strong" title="{{ localize 'WWN.ArmorClass' }}">
                        {{ localize "WWN.ArmorClassShort" }}</h4>
                    <div class="text-center p-1">
                        <input name="system.aac.value" type="number" value="{{system.aac.value}}" data-dtype="Number"
                            placeholder="10" data-dtype="Number" />
                    </div>
                </li>
                <li class="monster-skill-check">
                    <h4 class="bg-wwn-header-bg text-wwn-panel-title text-center p-0.5 border border-wwn-border-strong"><a>{{ localize "WWN.skill" }}</a>
                    </h4>
                    <div class="text-center p-1">
                        <input name="system.details.skill" type="number" value="{{system.details.skill}}" placeholder="0"
                            data-dtype="Number" />
                    </div>
                </li>
                <li>
                    <h4 class="bg-wwn-header-bg text-wwn-panel-title text-center p-0.5 border border-wwn-border-strong" title="{{localize 'WWN.movement.base'}}">
                        {{ localize "WWN.movement.monsterShort" }}
                    </h4>
                    <div class="flex flex-row text-center p-1">
                        <input name="system.movement.base" type="text" value="{{system.movement.base}}" placeholder="0"
                            data-dtype="text" />
                    </div>
                </li>
            </ul>
        </div>
        <div class="flex flex-row gap-2 flex-1">
            <ul class="attributes saves flex flex-col gap-1 flex-1">
                <li class="saving-throw" data-save="evasion">
                    <h4 class="bg-wwn-header-bg text-wwn-panel-title text-center p-0.5 border border-wwn-border-strong">
                        <a>{{ localize "WWN.saves.evasion" }}</a>
                    </h4>
                    <div class="text-center p-1">
                        <input name="system.saves.evasion.value" type="number" value="{{system.saves.evasion.value}}"
                            data-dtype="Number" disabled />
                </li>
                <li class="saving-throw" data-save="mental">
                    <h4 class="bg-wwn-header-bg text-wwn-panel-title text-center p-0.5 border border-wwn-border-strong">
                        <a>{{ localize "WWN.saves.mental" }}</a>
                    </h4>
                    <div class="text-center p-1">
                        <input name="system.saves.mental.value" type="number" value="{{system.saves.mental.value}}"
                            data-dtype="Number" disabled />
                </li>
            </ul>
            <ul class="attributes saves flex flex-col gap-1 flex-1">
                <li class="saving-throw" data-save="physical">
                    <h4 class="bg-wwn-header-bg text-wwn-panel-title text-center p-0.5 border border-wwn-border-strong">
                        <a>{{ localize "WWN.saves.physical" }}</a>
                    </h4>
                    <div class="text-center p-1">
                        <input name="system.saves.physical.value" type="number" value="{{system.saves.physical.value}}"
                            data-dtype="Number" disabled />
                </li>
                <li class="saving-throw" data-save="luck">
                    <h4 class="bg-wwn-header-bg text-wwn-panel-title text-center p-0.5 border border-wwn-border-strong">
                        <a>{{ localize "WWN.saves.luck" }}</a>
                    </h4>
                    <div class="text-center p-1">
                        <input name="system.saves.luck.value" type="number" value="{{system.saves.luck.value}}"
                            placeholder="0" data-dtype="Number" disabled />
                </li>
            </ul>
        </div>
    </section>
    <section class="flex flex-row attribute-row flex-[5] gap-2">
        {{!-- Skills and abilities --}}
        <div class="panel inventory abilities flex-1">
            <div>
                <li class="item-titles panel-title flex flex-row text-wwn-panel-title bg-wwn-header-bg text-center p-1 text-[13px] border border-wwn-border-strong">
                    <div class="item-name flex-1 min-w-0 indent-2 text-left">{{localize 'WWN.category.abilities'}} & {{localize 'WWN.category.equipment'}}
                    </div>
                    <div class="item-controls text-xs basis-[60px] text-right">
                        {{#if owner}}
                        <a class="item-control item-reset hover:text-wwn-accent-bright" data-action="item-reset" title='{{localize "WWN.items.resetAttacks"}}'><i
                                class="fas fa-sync"></i></a>
                        <a class="item-control item-search hover:text-wwn-accent-bright" data-action="item-search" data-type="weapon" title="{{localize 'WWN.Search'}}"><i
                            class="fa fa-search"></i></a>
                        <a class="item-control item-create hover:text-wwn-accent-bright" data-action="item-create" title='{{localize "WWN.Add"}}' data-type="choice"
                            data-choices="weapon,ability,armor,item"><i class="fas fa-plus"></i></a>
                        {{/if}}
                    </div>
                </li>
                <ol class="item-list resizable" data-base-size="240">
                    {{! Attack pattern group}}
                    {{#each attackPatterns as |item|}}
                        <li class="item-entry odd:bg-transparent even:bg-wwn-row-alt">
                            <div class="item flex flex-row leading-[30px] h-[30px] overflow-hidden" data-item-id="{{item.id}}">
                                <div class="item-name item-rollable flex flex-row flex-1 min-w-0 indent-2 text-left overflow-hidden">
                                    <div class="item-image" style="background-image: url({{item.img}})"></div>
                                    <p class="m-0" title="{{item.name}}">
                                        {{item.name~}}
                                    </p>
                                </div>
                                {{#if (eq type "weapon")}}
                                <div class="field-long counter flex flex-row basis-[80px] text-center text-xs">
                                    <input type="text" value="{{item.system.counter.value}}" data-dtype="Number"
                                        placeholder="0" data-field="value"
                                        title="{{localize 'WWN.items.roundAttacks'}}">
                                    /
                                    <input type="text" value="{{item.system.counter.max}}" data-field="max"
                                        data-dtype="Number" placeholder="0"
                                        title="{{localize 'WWN.items.roundAttacksMax'}}">
                                </div>
                                {{/if}}
                                <div class="item-controls text-xs basis-[60px] text-right">
                                    {{#if ../owner}}
                                    {{#if (eq type "ability")}}
                                    <a class="item-control item-show hover:text-wwn-accent-bright" data-action="item-show" title='{{localize "WWN.Show"}}'><i
                                            class="fas fa-eye"></i></a>
                                    {{/if}}
                                    <a class="item-control item-edit hover:text-wwn-accent-bright" data-action="item-edit" title='{{localize "WWN.Edit"}}'><i
                                            class="fas fa-edit"></i></a>
                                    <a class="item-control item-delete hover:text-wwn-accent-bright" data-action="item-delete" title='{{localize "WWN.Delete"}}'><i
                                            class="fas fa-trash"></i></a>
                                    {{/if}}
                                </div>
                            </div>
                        </li>
                    {{/each}}
                    {{! Other items}}
                    {{#each owned as |section id|}}
                    {{#unless (or (eq id "spells") (eq id "arts"))}}
                    {{#each section as |item|}}
                    <li class="item-entry odd:bg-transparent even:bg-wwn-row-alt">
                        <div class="item flex flex-row leading-[30px] h-[30px] overflow-hidden" data-item-id="{{item.id}}">
                            <div class="item-name item-rollable flex flex-row flex-1 min-w-0 indent-2 text-left overflow-hidden">
                                <div class="item-image" style="background-image: url({{item.img}})"></div>
                                <p class="m-0" title="{{item.name}}">
                                    {{item.name~}}
                                </p>
                            </div>
                            <div class="item-controls text-xs basis-[60px] text-right">
                                {{#if ../../owner}}
                                <a class="item-control item-edit hover:text-wwn-accent-bright" data-action="item-edit" title='{{localize "WWN.Edit"}}'><i
                                        class="fas fa-edit"></i></a>
                                <a class="item-control item-delete hover:text-wwn-accent-bright" data-action="item-delete" title='{{localize "WWN.Delete"}}'><i
                                        class="fas fa-trash"></i></a>
                                {{/if}}
                            </div>
                        </div>
                    </li>
                    {{/each}}
                    {{/unless}}
                    {{/each}}
                </ol>
            </div>
        </div>
    </section>
