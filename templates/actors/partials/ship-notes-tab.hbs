<section class="notes-tab">
    <div class="inventory">
        <div class="details-top flex flex-row flex-[2]">
            <div class="flex-[3]">
                <div class="item-titles flex flex-row bg-wwn-header-bg text-white border border-wwn-border-strong text-center py-1 text-[13px]">
                    <div class="item-name flex-1 min-w-0 indent-2 text-left">
                        {{localize 'WWN.category.fittingTitle'}}
                    </div>
                    <div class="field-short text-xs basis-[45px] text-center">
                        {{localize 'WWN.details.fittings.cost'}}
                    </div>
                    <div class="field-short text-xs basis-[45px] text-center">
                        {{localize 'WWN.details.fittings.cargo'}}
                    </div>
                    <div class="item-controls text-xs basis-[60px] text-right">
                        {{#if owner}}
                        <a class="item-control item-create hover:text-wwn-accent-bright" title='{{localize "WWN.Add"}}' data-type="fitting"
                            data-choices="fitting"><i class="fas fa-plus"></i></a>
                        {{/if}}
                    </div>
                </div>
                <ol class="item-list" data-base-size="100">
                    {{#each owned.fittings as |fitting|}}
                    <li class="item-entry odd:bg-transparent even:bg-wwn-row-alt">
                        <div class="item flex flex-row leading-[30px] h-[30px] overflow-hidden" data-item-id="{{fitting.id}}">
                            <div class="item-name item-rollable flex flex-row flex-1 min-w-0 indent-2 text-left overflow-hidden">
                                <div class="item-image" style="background-image: url({{img}})"></div>
                                <a>
                                    <p class="m-0" title="{{fitting.name}}">
                                        {{fitting.name~}}
                                    </p>
                                </a>
                            </div>
                            <div class="field-short text-xs basis-[45px] text-center" data-tooltip="{{localize 'WWN.details.fittings.costLong'}}">
                                {{fitting.system.cost}}                            
                            </div>
                            <div class="field-short text-xs basis-[45px] text-center" data-tooltip="{{localize 'WWN.details.fittings.cargoLong'}}">
                                {{fitting.system.cargo}}
                            </div>
                            <div class="item-controls text-xs basis-[60px] text-right">
                                {{#if ../owner}}
                                <a class="item-control item-show hover:text-wwn-accent-bright" title='{{localize "WWN.Show"}}'><i
                                        class="fas fa-eye"></i></a>
                                <a class="item-control item-edit hover:text-wwn-accent-bright" title='{{localize "WWN.Edit"}}'><i
                                        class="fas fa-edit"></i></a>
                                <a class="item-control item-delete hover:text-wwn-accent-bright" title='{{localize "WWN.Delete"}}'><i
                                        class="fas fa-trash"></i></a>
                                {{/if}}
                            </div>
                        </div>
                    </li>
                    {{/each}}
                </ol>
            </div>
        </div>
        <div>
            <div class="description">
                <div class="item-titles bg-wwn-header-bg text-white border border-wwn-border-strong text-center py-1 text-[13px]">
                    {{localize "WWN.category.description"}}
                </div>
                <div>
                    {{editor enrichedBiography target="system.details.biography"
                    button=true editable=editable async=true}}
                </div>
            </div>
            <div class="description">
                <div class="item-titles bg-wwn-header-bg text-white border border-wwn-border-strong text-center py-1 text-[13px]">{{localize "WWN.category.notes"}}</div>
                <div>
                    {{editor enrichedNotes target="system.details.notes"
                    button=true editable=editable async=true}}
                </div>
            </div>
        </div>
    </div>
</section>
