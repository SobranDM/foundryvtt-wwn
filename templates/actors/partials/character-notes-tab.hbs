<section class="notes-tab flex flex-col min-h-0 overflow-hidden">
  <div class="inventory flex flex-col min-h-0 flex-1">
    <div class="details-relocated item-titles flex flex-row items-center bg-wwn-header-bg text-white border border-wwn-border-strong text-center py-1 text-[13px] mt-[7px]">
      <div class="item-name flex-1 text-left indent-2">{{localize 'WWN.category.details'}}</div>
    </div>
    <div class="details-fields grid grid-cols-[repeat(auto-fill,minmax(140px,1fr))] gap-x-3 gap-y-1 py-2 px-1">
      <div class="form-group details-field flex flex-col gap-0.5">
        <label class="text-[11px] text-wwn-text-muted">{{localize 'WWN.details.level'}}</label>
        <input type="number" name="system.details.level" value="{{system.details.level}}" data-dtype="Number" min="1" class="border-b border-wwn-border-light text-sm font-semibold" />
      </div>
      <div class="form-group details-field flex flex-col gap-0.5">
        <label class="text-[11px] text-wwn-text-muted">XP</label>
        <div class="flex flex-row items-center gap-1">
          <input type="number" name="system.details.xp.value" value="{{system.details.xp.value}}" data-dtype="Number" class="border-b border-wwn-border-light text-sm flex-1" />
          <span class="text-wwn-text-muted text-xs">/</span>
          {{#if config.xpPerChar}}
          <input type="number" name="system.details.xp.next" value="{{system.details.xp.next}}" data-dtype="Number" class="border-b border-wwn-border-light text-sm w-[3em]" />
          {{else}}
          <input type="number" name="system.details.xp.next" value="{{system.details.xp.next}}" data-dtype="Number" disabled class="border-b border-wwn-border-light text-sm w-[3em]" />
          {{/if}}
          <div class="progress-bar w-[40px] h-1 min-w-[24px] bg-wwn-progress-bg border border-wwn-border rounded-sm overflow-hidden shrink-0" role="progressbar" aria-valuenow="{{xpPercent}}" aria-valuemin="0" aria-valuemax="100">
            <div class="progress-fill h-full bg-wwn-progress-xp-fill transition-[width] duration-200" style="width: {{xpPercent}}%;"></div>
          </div>
        </div>
      </div>
      <div class="form-group details-field flex flex-col gap-0.5">
        <label class="text-[11px] text-wwn-text-muted">{{localize 'WWN.details.class'}}</label>
        <input type="text" name="system.details.class" value="{{system.details.class}}" data-dtype="String" class="border-b border-wwn-border-light text-sm" />
      </div>
      <div class="form-group details-field flex flex-col gap-0.5">
        <label class="text-[11px] text-wwn-text-muted">{{localize 'WWN.details.background'}}</label>
        <input type="text" name="system.details.background" value="{{system.details.background}}" data-dtype="String" class="border-b border-wwn-border-light text-sm" />
      </div>
      <div class="form-group details-field flex flex-col gap-0.5">
        <label class="text-[11px] text-wwn-text-muted">{{localize 'WWN.details.alignment'}}</label>
        <input type="text" name="system.details.alignment" value="{{system.details.alignment}}" data-dtype="String" class="border-b border-wwn-border-light text-sm" />
      </div>
      <div class="form-group details-field flex flex-col gap-0.5">
        <label class="text-[11px] text-wwn-text-muted">{{localize 'WWN.ABShort'}}</label>
        <input type="number" name="system.thac0.bba" value="{{system.thac0.bba}}" placeholder="0" data-dtype="Number" class="border-b border-wwn-border-light text-sm" />
      </div>
      <div class="form-group details-field check-field flex flex-col gap-0.5" data-stat="hd">
        <label class="text-[11px] text-wwn-text-muted">{{localize 'WWN.HitDiceLong'}}</label>
        <div class="flex flex-row items-center gap-1">
          <div class="check hd-roll cursor-pointer" title="{{localize 'WWN.HitDice'}}"><a><i class="fas fa-dice text-wwn-accent hover:text-wwn-accent-bright"></i></a></div>
          <input type="text" name="system.hp.hd" value="{{system.hp.hd}}" title="{{localize 'WWN.HitDiceFormula'}}" class="border-b border-wwn-border-light text-sm flex-1" />
        </div>
      </div>
      {{#if config.useTrauma}}
      <div class="form-group details-field flex flex-col gap-0.5">
        <label class="text-[11px] text-wwn-text-muted">{{localize 'WWN.TraumaTargetMedium'}}</label>
        <input type="number" name="system.trauma.value" value="{{system.trauma.value}}" data-dtype="Number"
          placeholder="6" disabled data-tooltip="{{localize 'WWN.TraumaTargetLong'}}" class="border-b border-wwn-border-light text-sm" />
      </div>
      {{/if}}
      {{#if system.retainer.enabled}}
      <div class="form-group details-field flex flex-col gap-0.5">
        <label class="text-[11px] text-wwn-text-muted">{{localize 'WWN.RetainerWage'}}</label>
        <input type="text" name="system.retainer.wage" value="{{system.retainer.wage}}" data-dtype="String" class="border-b border-wwn-border-light text-sm" />
      </div>
      <div class="form-group details-field check-field flex flex-col gap-0.5" data-stat="lr">
        <label class="text-[11px] text-wwn-text-muted">{{localize 'WWN.Loyalty'}}</label>
        <div class="flex flex-row items-center gap-1">
          <div class="check morale-check cursor-pointer" title="{{localize 'WWN.roll.morale'}}"><a><i class="fas fa-dice text-wwn-accent hover:text-wwn-accent-bright"></i></a></div>
          <input name="system.details.morale" type="number" value="{{system.details.morale}}" placeholder="0" data-dtype="Number" class="border-b border-wwn-border-light text-sm flex-1" />
        </div>
      </div>
      {{else}}
      <div class="form-group details-field flex flex-col gap-0.5">
        <label class="text-[11px] text-wwn-text-muted">{{localize 'WWN.details.renown.short'}}</label>
        <input type="number" name="system.details.renown.value" value="{{system.details.renown.value}}" data-dtype="Number" class="border-b border-wwn-border-light text-sm" />
      </div>
      {{/if}}
    </div>
    <div class="details-top flex flex-row gap-2 mt-1">
      <div class="languages flex-[0_0_180px]">
        <div class="item-titles flex flex-row items-center bg-wwn-header-bg text-white border border-wwn-border-strong text-center py-1 text-[13px]">
          <div class="item-name flex-1 text-left indent-2">{{localize "WWN.category.languages"}}</div>
          <div class="item-controls text-xs basis-[60px] grow-0 text-right mr-1">
            <a class="item-control item-push hover:text-wwn-accent-bright" data-action="item-push" data-array="languages" title="{{localize 'WWN.Add'}}"><i class="fa fa-plus"></i></a>
          </div>
        </div>
        <ol class="item-list list-none m-0 p-0" data-base-size="80">
          {{#each system.languages.value as |lang|}}
          <li class="item flex flex-row items-center h-[28px] overflow-hidden text-[12px] odd:bg-transparent even:bg-wwn-row-alt" data-lang="{{lang}}">
            <div class="item-name flex-1 text-left indent-2">{{lang}}</div>
            <div class="item-controls text-xs basis-[40px] grow-0 text-right mr-1">
              <a class="item-control item-pop hover:text-wwn-accent-bright" data-action="item-pop" data-array="languages" title="{{localize 'WWN.Del'}}"><i class="fa fa-trash"></i></a>
            </div>
          </li>
          {{/each}}
        </ol>
      </div>
    </div>
    <div class="mt-2 flex flex-col gap-2 flex-shrink-0">
      <div class="description border border-wwn-border rounded overflow-hidden">
        <div class="item-titles bg-wwn-header-bg text-white border-b border-wwn-border-strong text-center py-1 text-[13px]">{{localize "WWN.category.description"}}</div>
        <div class="min-h-[120px] p-1 bg-wwn-bg">
          {{editor enrichedBiography target="system.details.biography" button=true editable=editable async=true}}
        </div>
      </div>
      <div class="description border border-wwn-border rounded overflow-hidden">
        <div class="item-titles bg-wwn-header-bg text-white border-b border-wwn-border-strong text-center py-1 text-[13px]">{{localize "WWN.category.notes"}}</div>
        <div class="min-h-[120px] p-1 bg-wwn-bg">
          {{editor enrichedNotes target="system.details.notes" button=true editable=editable async=true}}
        </div>
      </div>
    </div>
  </div>
</section>
