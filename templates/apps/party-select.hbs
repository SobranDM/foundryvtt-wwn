<form autocomplete="off" onsubmit="event.preventDefault();">
  <ol class="actor-list list-none p-0 m-0">
    {{#each actors as |actor key|}}
    <li class="form-group actor flex flex-row items-center gap-1 py-0.5" data-actor-id="{{actor.id}}">
      <label class="flex-1">{{actor.name}}</label>
      <div class="form-fields shrink-0">
        <input type="checkbox" data-action="select-actor" name="{{key}}" data-dtype="Boolean" {{checked
          actor.flags.wwn.party}} />
      </div>
    </li>
    {{/each}}
  </ol>
</form>
