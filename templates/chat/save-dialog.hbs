<form class="save-dialog flex flex-col gap-2">
  <h3 class="text-sm m-0">Selected Token Saves</h3>
  <div class="form-group flex flex-row items-center gap-1 save-dialog-header">
    <label class="flex-1">Roll Modifier</label>
    <input class="save-dialog-global-modifier w-20" type="number" name="globalModifier" value="0" />
  </div>

  <div class="form-group save-dialog-body">
    <h3 class="text-sm m-0 mb-1">Individual Save Modifiers</h3>
    <p class="text-xs text-wwn-text-muted m-0 mb-1">These modifiers replace the roll modifier above.</p>
    <div class="token-modifiers flex flex-col gap-0.5">
      {{#each tokens}}
      <div class="form-group flex flex-row items-center gap-1">
        <label class="flex-1">{{name}}</label>
        <input type="number" name="modifier-{{id}}" value="" placeholder="Override" class="w-20" />
      </div>
      {{/each}}
    </div>
  </div>
</form>
