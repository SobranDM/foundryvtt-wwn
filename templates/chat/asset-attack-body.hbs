{{#if attackSpecial}}
 {{attackSpecial}} <br>
{{/if}}

<span>{{ attackKey }}:</span>
<span>{{{ hitRoll }}}</span>
<span>{{localize 'WWN.faction.damage'}}:</span>
<span>{{{ damageRoll }}}</span>

{{#if assetsWithLocationNotes}}
<b>{{localize 'WWN.faction.locationRollTitle'}}</b>:<br>
  {{#each assetsWithLocationNotes as |faitems|}}
  <i>{{faitems.name}}</i>: {{faitems.system.locationRoll}}<br>
  {{/each}}
{{/if}}
