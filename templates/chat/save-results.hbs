<div class="wwn">
  <div class="wwn chat-block border border-wwn-border px-2 py-1 my-1 bg-wwn-bg-elevated text-wwn-text">
    <div class="save-header flex flex-row items-center justify-between font-bold mb-1">
      {{saveType}} Saves
      <div class="save-actions flex flex-row gap-1">
        {{#if hasSuccessfulSaves}}
        <button class="select-tokens text-xs" data-action="select-successful">
          <i class="fas fa-check-circle"></i> Select Successful
        </button>
        {{/if}}
        {{#if hasFailedSaves}}
        <button class="select-tokens text-xs" data-action="select-failed">
          <i class="fas fa-times-circle"></i> Select Failed
        </button>
        {{/if}}
      </div>
    </div>

    <div class="blindable" data-blind="{{blindroll}}">
      {{#if hasSuccessfulSaves}}
      <div class="save-group mb-1">
        <div class="save-group-header font-semibold text-wwn-success text-sm mb-0.5">Successful Saves</div>
        <ul class="save-list list-none p-0 m-0">
          {{#each results}}
          {{#if isSuccess}}
          <li class="save-item flex flex-row items-center justify-between py-0.5" data-token-id="{{tokenId}}">
            <span class="token-name font-medium">{{name}}</span>
            <span class="roll-details text-wwn-text-muted text-xs">({{roll.total}}{{#if modifier}}{{#if (gt modifier 0)}}+{{/if}}{{modifier}}{{/if}}
              vs {{target}})</span>
          </li>
          {{/if}}
          {{/each}}
        </ul>
      </div>
      {{/if}}

      {{#if hasFailedSaves}}
      <div class="save-group mb-1">
        <div class="save-group-header font-semibold text-wwn-failure text-sm mb-0.5">Failed Saves</div>
        <ul class="save-list list-none p-0 m-0">
          {{#each results}}
          {{#if isFailure}}
          <li class="save-item flex flex-row items-center justify-between py-0.5" data-token-id="{{tokenId}}">
            <span class="token-name font-medium">{{name}}</span>
            <span class="roll-details text-wwn-text-muted text-xs">({{roll.total}}{{#if modifier}}{{#if (gt modifier 0)}}+{{/if}}{{modifier}}{{/if}}
              vs {{target}})</span>
          </li>
          {{/if}}
          {{/each}}
        </ul>
      </div>
      {{/if}}

      {{#each results}}
      <div class="save-roll" style="display: none;">
        {{{rollWWN}}}
      </div>
      {{/each}}
    </div>
  </div>
</div>
