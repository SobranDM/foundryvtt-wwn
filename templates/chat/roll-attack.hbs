<div class="wwn chat-card item-card" data-actor-id="{{data.actor._id}}" data-item-id="{{data.item._id}}" {{#if
  tokenId}}data-token-id="{{tokenId}}" {{/if}}>
  <div class="wwn chat-block border border-wwn-border px-2 py-1 my-1 bg-wwn-bg-elevated text-wwn-text">
    <div class="flex flex-row chat-header items-center gap-1 mb-2">
      <div class="chat-title flex-1">
        <h2 class="text-sm m-0">{{title}}</h2>
      </div>
      {{#if data.item}}
      <div class="chat-img w-9 h-9 shrink-0 bg-cover bg-center rounded" style="background-image:url('{{data.item.img}}')"></div>
      {{else}}
      <div class="chat-img w-9 h-9 shrink-0 bg-cover bg-center rounded" style="background-image:url('{{data.actor.img}}')"></div>
      {{/if}}
    </div>
    {{#if result.victim}}
    <div class="chat-target text-sm italic mb-1">
      vs {{result.victim}}
    </div>
    {{/if}}
    <div class="blindable" data-blind="{{data.roll.blindroll}}">
      <div class="chat-details">
        <div class="roll-result">{{{result.details}}}</div>
      </div>
      {{#if rollWWN}}<div title="{{rollTitle}}">{{{rollWWN}}}</div>{{/if}}
      {{#if result.isSuccess}}
      <div class="chat-details">
        <div class="roll-result font-bold"><b>{{localize 'WWN.messages.InflictsDamage'}}</b></div>
      </div>
      <div class="damage-roll" title="{{dmgTitle}}">{{{rollDamage}}}</div>
      {{/if}}
      {{#if (nt data.item.system.shock.damage null)}}
      {{#if data.item.system.shock.ac}}
      <div class="chat-details shock-message">
        <div class="roll-result font-bold"><b>{{localize 'WWN.messages.applyShock1'}}
            <span class="dice-total">{{data.item.system.shockTotal}}</span>
            {{localize 'WWN.messages.applyShock2'}}{{data.item.system.shock.ac}}</b>
        </div>
      </div>
      {{/if}}
      {{#unless data.item.system.shock.ac}}
      <div class="chat-details shock-message">
        <div class="roll-result font-bold"><b>{{localize 'WWN.messages.applyShock1'}}
            <span class="dice-total">{{data.item.system.shockTotal}}</span>
            {{localize 'WWN.messages.applyShockAlt'}}</b>
        </div>
      </div>
      {{/unless}}
      {{/if}}

      <div class="card-buttons flex flex-col gap-1 mt-1.5">
        {{#if data.roll.save}}
        <button data-action="save" data-save="{{data.roll.save}}" data-blind-roll="{{data.roll.blindroll}}">
          {{lookup config.saves data.roll.save}} - {{localize "WWN.spells.Save"}}
        </button>
        {{/if}}
        {{#if (nt data.item.system.shock.damage null)}}
        <button data-action="apply-shock" data-damage="{{data.item.system.shockTotal}}" data-damage-multiplier="1">Apply
          Shock</button>
        {{/if}}

        {{#if straightDamage}}
        <!-- GODBOUND DAMAGE BUTTONS -->
        <div class="flex flex-row gap-1">
          <button data-action="apply-damage" data-damage="{{rollDamage}}" data-damage-multiplier="1"
            class="flex-1">Apply Damage</button>
          <button data-action="apply-damage" data-damage="{{straightDamage}}" data-damage-multiplier="1"
            class="flex-1">Straight Damage</button>
        </div>
        <div class="flex flex-row gap-1">
          <button data-action="apply-damage" data-damage="{{rollDamage}}" data-damage-multiplier="-1"
            class="flex-1">Apply Healing</button>
          <button data-action="apply-damage" data-damage="{{straightDamage}}" data-damage-multiplier="-1"
            class="flex-1">Straight Healing</button>
        </div>
        {{else}}
        <!-- NORMAL DAMAGE BUTTONS -->
        <div class="flex flex-row gap-1">
          <button data-action="apply-damage" data-damage="{{rollDamage}}" data-damage-multiplier="1"
            class="flex-[2]">Apply
            Damage</button>
          <button data-action="apply-damage" data-damage="{{rollDamage}}" data-damage-multiplier="0.5"
            class="flex-1">1/2</button>
          <button data-action="apply-damage" data-damage="{{rollDamage}}" data-damage-multiplier="2" class="flex-1">x2</button>
        </div>

        <div class="flex flex-row gap-1">
          <button data-action="apply-damage" data-damage="{{rollDamage}}" data-damage-multiplier="-1"
            class="flex-[2]">Apply
            Healing</button>
          <button data-action="apply-damage" data-damage="{{rollDamage}}" data-damage-multiplier="-0.5"
            class="flex-1">1/2</button>
          <button data-action="apply-damage" data-damage="{{rollDamage}}" data-damage-multiplier="-2" class="flex-1">x2</button>
        </div>
        {{/if}}
      </div>

      {{#if traumaResult}}
      <!-- Always show trauma die roll -->
      <div class="chat-details">
        <div class="roll-result font-bold"><b>{{localize 'WWN.messages.TraumaDie'}}</b></div>
      </div>
      <div class="trauma-roll" title="Trauma Roll">{{{traumaRollWWN}}}</div>

      {{#if traumaResult.target}}
      <!-- If there's a target, show target and check if traumatic -->
      <div class="chat-details">
        <div class="roll-result font-bold"><b>{{localize 'WWN.messages.TraumaTarget'}} {{traumaResult.target}}</b></div>
      </div>

      {{#if traumaResult.isTraumatic}}
      <div class="chat-details trauma-message">
        <div class="roll-result"><b class="text-wwn-failure">{{localize 'WWN.messages.TraumaticHit'}}</b></div>
      </div>
      {{else}}
      <div class="chat-details trauma-message">
        <div class="roll-result"><b class="text-wwn-success">{{localize 'WWN.messages.NotTraumaticHit'}}</b></div>
      </div>
      {{/if}}
      {{/if}}

      {{#if traumaResult.isTraumatic}}
      <!-- TRAUMA DAMAGE DISPLAY AND BUTTONS -->
      <div class="chat-details trauma-damage-message">
        <div class="roll-result"><b class="text-lg">{{localize
            'WWN.messages.TraumaDamage'}} (x{{data.item.system.trauma.rating}}): {{traumaResult.damage}}</b></div>
      </div>

      <!-- TRAUMA DAMAGE BUTTONS -->
      <div class="flex flex-row gap-1 card-buttons mt-1.5">
        <button data-action="apply-damage" data-damage="{{traumaResult.damage}}" data-damage-multiplier="1"
          class="flex-[2]">Apply Damage</button>
        <button data-action="apply-damage" data-damage="{{traumaResult.damage}}" data-damage-multiplier="0.5"
          class="flex-1">1/2</button>
        <button data-action="apply-damage" data-damage="{{traumaResult.damage}}" data-damage-multiplier="2" class="flex-1">x2</button>
      </div>
      {{/if}}
      {{/if}}

    </div>
  </div>
</div>
