<h4>{{{ attackDesc }}}</h4>

<span>{{localize 'WWN.faction.att-roll'}}:</span>
<span>{{{ hitRoll }}}</span>
{{#if attackSpecial}}
 <i>{{attackSpecial}}</i> <br>
{{/if}}

<span>{{localize 'WWN.faction.def-roll'}}:</span>
<span>{{{ defRoll }}}</span>
{{#if defenseSpecial}}
 <i>{{defenseSpecial}}</i> <br>
{{/if}}

<span>{{{ attackDesc }}}</span>

{{#if attackDamage}}
<span>{{localize 'WWN.faction.att-damage'}}:</span>
<span>{{{ attackDamage }}}</span>
<span> (If Base of Infl damage to FactionHP also) </span>
{{/if}}

{{#if defDamage}}
<span>{{localize 'WWN.faction.def-damage'}}:</span>
<span>{{{ defDamage }}}</span>
{{/if}}

{{#if attackingAssetsWithLocationNotes}}
<b>{{localize 'WWN.faction.locationRollTitleAttack'}}</b>:<br>
  {{#each attackingAssetsWithLocationNotes as |faitems|}}
  <i>{{faitems.name}}</i> : {{faitems.system.locationRoll}}<br>
  {{/each}}
{{/if}}

{{#if attackedAssetsWithLocationNotes}}
<b>{{localize 'WWN.faction.locationRollTitleCounter'}}</b>:<br>
  {{#each attackedAssetsWithLocationNotes as |faitems|}}
  <i>{{faitems.name}}</i> : {{faitems.system.locationRoll}}<br>
  {{/each}}
{{/if}}
