{{!-- Active Effects categories: Temporary / Passive / Inactive.
      Shared by PC, NPC, and item Effects tabs. --}}
<div class="wwn-form-stack wwn-effects-list">
  {{#each effects as |section sid|}}
  <div class="wwn-form-panel" data-effect-type="{{section.type}}">
    <div class="wwn-section-header flexrow">
      <span class="wwn-collapsible-label">{{localize section.label}}</span>
      <div class="item-controls">
        <a class="item-control" data-action="effectAction" data-action-type="create"
          title="{{localize 'WWN.EffectCreate'}}">
          <i class="fas fa-plus"></i> {{localize "WWN.Add"}}
        </a>
      </div>
    </div>
    <div class="wwn-data-table">
      <div class="item-titles wwn-col-header flexrow">
        <div class="item-name">{{localize "WWN.Sheet.Name"}}</div>
        <div class="field-long">{{localize "WWN.Effect.Source"}}</div>
        <div class="field-long">{{localize "WWN.Effect.Duration"}}</div>
        <div class="item-controls"></div>
      </div>
      <ol class="item-list">
        {{#each section.effects as |effect|}}
        <li class="item-entry" data-effect-id="{{effect.id}}" data-parent-id="{{effect.parent.id}}">
          <div class="item flexrow{{#if effect.disabled}} greyrow{{/if}}">
            <div class="item-name flexrow">
              <img class="item-image" src="{{effect.img}}" alt="" />
              <h4>{{effect.name}}</h4>
            </div>
            <div class="field-long">{{effect.sourceName}}</div>
            <div class="field-long">{{effect.duration.label}}</div>
            <div class="item-controls">
              <a class="item-control" data-action="effectAction" data-action-type="toggle"
                title="{{localize 'WWN.EffectToggle'}}">
                <i class="fas {{#if effect.disabled}}fa-check{{else}}fa-times{{/if}}"></i>
              </a>
              <a class="item-control" data-action="effectAction" data-action-type="edit"
                title="{{localize 'WWN.EffectEdit'}}">
                <i class="fas fa-edit"></i>
              </a>
              <a class="item-control" data-action="effectAction" data-action-type="delete"
                title="{{localize 'WWN.EffectDelete'}}">
                <i class="fas fa-trash"></i>
              </a>
            </div>
          </div>
        </li>
        {{/each}}
      </ol>
    </div>
  </div>
  {{/each}}
</div>
