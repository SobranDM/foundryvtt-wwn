<section class="flex flex-col gap-2 tab p-2" data-group="primary" data-tab="description">
  <div class="description flex-1 overflow-auto min-h-[200px]">
    {{editor enrichedDescription target="system.description" button=true owner=owner editable=editable async=true}}
  </div>
  <div class="flex flex-row gap-3">
    <div class="stats flex-1 border border-wwn-border p-0.5 text-[13px]">
      <div class="form-group flex items-center m-px border border-wwn-border">
        <label class="bg-wwn-row-alt px-2 whitespace-nowrap text-center leading-[21px] min-w-[100px] text-xs">{{localize 'WWN.items.Treasure'}}</label>
        <div class="form-fields flex-1 flex justify-center h-[22px]">
          <input type="checkbox" name="system.treasure" value="{{system.treasure}}" {{checked system.treasure}}
            data-dtype="Boolean" data-tooltip="{{localize 'WWN.items.cargoTreasure'}}" />
        </div>
      </div>
      <div class="form-group flex items-center m-px border border-wwn-border">
        <label class="bg-wwn-row-alt px-2 whitespace-nowrap text-center leading-[21px] min-w-[100px] text-xs" title="{{localize 'WWN.items.Charges'}}">{{localize 'WWN.items.Charges'}}</label>
        <div class="form-fields flex-1 flex justify-evenly h-[22px]">
          <input class="w-10 text-center text-xs" type="number" name="system.charges.value" value="{{system.charges.value}}" data-dtype="Number"
            title="{{localize 'WWN.items.CurrCharges'}}" />
          <input class="w-10 text-center text-xs" type="number" name="system.charges.max" value="{{system.charges.max}}" data-dtype="Number"
            title="{{localize 'WWN.items.MaxCharges'}}" />
        </div>
      </div>
    </div>
  </div>
</section>
