<header class="sheet-header flex flex-row gap-2 p-2 border-b border-wwn-border items-center">
  <img class="profile-img border-0 w-[84px] h-[84px] object-contain flex-none" src="{{img}}" data-edit="img" title="{{name}}" />
  <div class="header-col flex flex-col flex-1 min-w-0 gap-1">
    <div class="flex flex-row items-center gap-2">
      <h1 class="charname flex-1 m-0">
        <input class="text-lg font-bold bg-transparent border-b border-wwn-border w-full px-1 py-0.5" name="name" type="text" value="{{name}}" placeholder="Name" />
      </h1>
      <div class="details flex flex-row gap-2 shrink-0">
        <div class="form-group flex items-center gap-1">
          <label class="text-xs text-wwn-text-muted" title="{{localize 'WWN.items.Price'}}"><i class="fas fa-circle"></i></label>
          <div class="form-fields">
            <input class="w-12 text-center text-xs" type="number" name="system.price" value="{{system.price}}" data-dtype="Number" />
          </div>
        </div>
        <div class="form-group flex items-center gap-1">
          <label class="text-xs text-wwn-text-muted" title="{{localize 'WWN.items.cargo.general'}}"><i class="fas fa-weight-hanging"></i></label>
          <div class="form-fields">
            <input class="w-12 text-center text-xs" type="number" name="system.weight" value="{{system.weight}}" data-dtype="Number" />
          </div>
        </div>
        <div class="form-group flex items-center gap-1">
          <label class="text-xs text-wwn-text-muted" title="{{localize 'WWN.items.Quantity'}}"><i class="fas fa-hashtag"></i></label>
          <div class="form-fields">
            <input class="w-12 text-center text-xs" type="number" name="system.quantity" value="{{system.quantity}}" data-dtype="Number" />
          </div>
        </div>
      </div>
    </div>
    <ol class="tag-list m-0 h-6 overflow-auto list-none p-px flex flex-wrap gap-1">
      {{#each system.tags as |tag|}}
      <li class="tag bg-wwn-tag-bg rounded text-wwn-tag-text px-1.5 py-px text-[11px] leading-4 flex items-center gap-0.5" title="{{getTagDesc tag.value}}" data-tag="{{tag.value}}">
        <span>{{tag.value}}</span>
        <a class="tag-delete text-wwn-tab-bg text-[8px] cursor-pointer"><i class="fas fa-times"></i></a>
      </li>
      {{/each}}
    </ol>
  </div>
</header>
