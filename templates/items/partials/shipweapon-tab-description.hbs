<section class="flex flex-col gap-2 tab p-2" data-group="primary" data-tab="description">
  <div class="description flex-1 overflow-auto min-h-[150px]">
    {{editor enrichedDescription target="system.description" button=true owner=owner editable=editable async=true}}
  </div>
  <div class="flex flex-row gap-3">
    <div class="stats flex-1 border border-wwn-border p-0.5 text-[13px]">
      <div class="form-group flex items-center m-px border border-wwn-border">
        <label class="bg-wwn-row-alt px-2 whitespace-nowrap text-center leading-[21px] min-w-[100px] text-xs">{{localize 'WWN.items.AtkBonus'}}</label>
        <div class="form-fields flex-1 flex justify-evenly h-[22px]">
          <input class="flex-1 text-center text-xs" type="string" name="system.bonus" value="{{system.bonus}}" data-dtype="String" />
        </div>
      </div>
      <div class="form-group flex items-center m-px border border-wwn-border">
        <label class="bg-wwn-row-alt px-2 whitespace-nowrap text-center leading-[21px] min-w-[100px] text-xs">{{localize 'WWN.items.weapon.range'}}</label>
        <div class="form-fields flex-1 flex justify-evenly h-[22px]">
          <select class="h-6 text-xs" name="system.range">
            {{selectOptions config.ranges selected=system.range localize=true}}
          </select>
        </div>
      </div>
      <div class="form-group flex items-center m-px border border-wwn-border">
        <label class="bg-wwn-row-alt px-2 whitespace-nowrap text-center leading-[21px] min-w-[100px] text-xs">{{localize 'WWN.items.weapon.size'}}</label>
        <div class="form-fields flex-1 flex justify-evenly h-[22px]">
          <select class="h-6 text-xs" name="system.size">
            {{selectOptions config.sizes selected=system.size localize=true}}
          </select>
        </div>
      </div>
    </div>
    <div class="stats flex-1 border border-wwn-border p-0.5 text-[13px]">
      <div class="form-group flex items-center m-px border border-wwn-border">
        <label class="bg-wwn-row-alt px-2 whitespace-nowrap text-center leading-[21px] min-w-[100px] text-xs">{{localize 'WWN.items.Damage'}}</label>
        <div class="form-fields flex-1 flex justify-evenly h-[22px]">
          <input class="flex-1 text-center text-xs" type="text" name="system.damage" value="{{system.damage}}" data-dtype="String" />
        </div>
      </div>
      <div class="form-group flex items-center m-px border border-wwn-border">
        <label class="bg-wwn-row-alt px-2 whitespace-nowrap text-center leading-[21px] min-w-[100px] text-xs">{{localize 'WWN.items.weapon.ship'}}</label>
        <div class="form-fields flex-1 flex justify-center h-[22px]">
          <input type="checkbox" title="{{localize 'WWN.items.weapon.shiptooltip'}}" name="system.ship" value="{{system.ship}}" {{checked system.ship}}
            data-dtype="Boolean" />
        </div>
      </div>
      <div class="form-group flex items-center m-px border border-wwn-border">
        <label class="bg-wwn-row-alt px-2 whitespace-nowrap text-center leading-[21px] min-w-[100px] text-xs">{{localize 'WWN.items.crew.current'}}</label>
        <div class="form-fields flex-1 flex justify-evenly h-[22px]">
          <input class="flex-1 text-center text-xs" type="text" name="system.crew" value="{{system.crew}}" data-dtype="String" />
        </div>
      </div>
    </div>
  </div>
</section>
