<form class="wwn roll-dialog p-2">
  <div class="form-group flex items-center py-[3px]">
    <label class="flex-[0_0_120px]">{{localize "WWN.dialog.skillDice"}}</label>
    <select class="flex-1" name="skillDice">
      {{selectOptions diceChoices selected=dicePool}}
    </select>
  </div>
  <div class="form-group flex items-center py-[3px]">
    <label class="flex-[0_0_120px]">{{localize "WWN.attribute"}}</label>
    <select class="flex-1" name="score">
      <option value=""></option>
      {{selectOptions choices selected=defaultScore localize=true}}
    </select>
  </div>
  <div class="form-group flex items-center py-[3px]">
    <label class="flex-[0_0_120px]">{{localize "WWN.SitMod"}}</label>
    <input class="flex-1" type="number" name="bonus" value="0" placeholder="{{localize 'WWN.RollExample'}}" />
  </div>
  <div class="form-group flex items-center py-[3px]">
    <label class="flex-[0_0_120px]">{{localize "WWN.RollMode"}}</label>
    <select class="flex-1" name="rollMode">
      {{#each rollModes as |value mode|}}
      <option value="{{mode}}">{{localize value.label}}</option>
      {{/each}}
    </select>
  </div>
</form>
