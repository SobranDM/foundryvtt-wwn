<form class="wwn roll-dialog p-2">
  <div class="flex flex-col gap-1">
    <h1 class="text-lg font-bold text-wwn-text"> {{name}}</h1>
    <div class="form-group flex flex-row items-center py-[3px]">
      <label class="flex-[0_0_120px]" for="name">Crew type:</label>
      <input class="flex-1" id="name" type="text" value="{{name}}">
    </div>
    {{#if item}}
    <div class="form-group flex flex-row items-center py-[3px]">
      <label class="flex-[0_0_120px]" for="price">Cost/Month:</label>
      <input class="flex-1" id="price" type="text" value="0" data-dtype="number">
    </div>
    <div class="form-group flex flex-row items-center py-[3px]">
      <label class="flex-[0_0_120px]" for="quantity">Quantity:</label>
      <input class="flex-1" id="quantity" type="text" value="1" data-dtype="number">
    </div>
    {{/if}}
    {{#if crewmember}}
    <div class="form-group flex flex-row items-center py-[3px]">
      <label class="flex-[0_0_120px]" for="strength">Charges Value:</label>
      <input class="flex-1" id="strength" type="text" value="1" data-dtype="number">
    </div>
    <div class="form-group flex flex-row items-center py-[3px] gap-2">
      <label for="pc">Is PC?:</label>
      <input id="pc" type="checkbox" value="false" data-dtype="boolean">
      <label for="row">Is Rower?:</label>
      <input id="row" type="checkbox" value="false" data-dtype="boolean">
    </div>
    {{/if}}
  </div>
</form>
