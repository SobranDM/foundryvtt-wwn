{{!-- NPC/monster sheet header: Name, HD, Alignment, XP Award (HP is on Main). --}}
<header class="sheet-header wwn-sheet-header wwn-npc-header">
  <div class="wwn-header-identity">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" alt="" />
    <div class="wwn-header-identity-fields">
      <div class="wwn-header-row wwn-header-row--primary">
        <input class="wwn-header-name" name="name" type="text" value="{{actor.name}}"
          placeholder="{{localize 'WWN.details.name'}}" />
        <label class="wwn-chip" title="{{localize 'WWN.HitDiceLong'}}">
          <span class="wwn-chip-label">{{localize "WWN.HitDiceLong"}}</span>
          <input type="text" name="system.hd" value="{{system.hd}}" />
        </label>
        <label class="wwn-chip" title="{{localize 'WWN.details.experience.award'}}">
          <span class="wwn-chip-label">{{localize "WWN.details.experience.award"}}</span>
          <input type="number" name="system.details.xp" value="{{system.details.xp}}" data-dtype="Number" />
        </label>
      </div>
      <div class="wwn-header-row wwn-header-row--secondary">
        <label class="wwn-chip wwn-chip--grow">
          <span class="wwn-chip-label">{{localize "WWN.details.alignment"}}</span>
          <input type="text" name="system.details.alignment" value="{{system.details.alignment}}" />
          <a data-action="rollReaction" title="{{localize 'WWN.roll.reaction'}}"><i class="fas fa-dice"></i></a>
        </label>
      </div>
    </div>
  </div>
</header>
