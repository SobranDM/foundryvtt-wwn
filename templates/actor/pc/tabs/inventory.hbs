{{!-- Inventory tab: GWN-aligned single stack — purse strip, then weapons,
      armor, consumables, misc (containers), personal/party treasure, treasure,
      and currency items. --}}
<section class="tab inventory {{tab.cssClass}}" data-group="{{tab.group}}" data-tab="{{tab.id}}">
  <div class="wwn-inventory-stack wwn-data-table">

    {{!-- Actor purse / totals (was the right rail) --}}
    <div class="wwn-panel wwn-inventory-purse">
      <div class="wwn-inventory-purse-header">
        <span class="wwn-section-header">
          {{localize "WWN.items.Currency"}}
          <a data-action="adjustCurrency" title="{{localize 'WWN.items.adjustCurrency'}}" class="currency-adjust">
            <i class="fas fa-balance-scale"></i>
          </a>
        </span>
      </div>
      <div class="wwn-inventory-purse-fields">
        <label class="wwn-purse-field" title="{{localize 'WWN.items.CP.long'}}">
          <span class="wwn-purse-label">{{localize "WWN.items.CP.short"}}</span>
          <input class="currency" name="system.currency.cp" type="number" value="{{system.currency.cp}}"
            data-dtype="Number" placeholder="0" />
        </label>
        <label class="wwn-purse-field" title="{{localize 'WWN.items.SP.long'}}">
          <span class="wwn-purse-label">{{localize "WWN.items.SP.short"}}</span>
          <input class="currency" name="system.currency.sp" type="number" value="{{system.currency.sp}}"
            data-dtype="Number" placeholder="0" />
        </label>
        {{#if (eq currencyTypes "currencybx")}}
        <label class="wwn-purse-field" title="{{localize 'WWN.items.EP.long'}}">
          <span class="wwn-purse-label">{{localize "WWN.items.EP.short"}}</span>
          <input class="currency" name="system.currency.ep" type="number" value="{{system.currency.ep}}"
            data-dtype="Number" placeholder="0" />
        </label>
        {{/if}}
        <label class="wwn-purse-field" title="{{localize 'WWN.items.GP.long'}}">
          <span class="wwn-purse-label">{{localize "WWN.items.GP.short"}}</span>
          <input class="currency" name="system.currency.gp" type="number" value="{{system.currency.gp}}"
            data-dtype="Number" placeholder="0" />
        </label>
        {{#if (eq currencyTypes "currencybx")}}
        <label class="wwn-purse-field" title="{{localize 'WWN.items.PP.long'}}">
          <span class="wwn-purse-label">{{localize "WWN.items.PP.short"}}</span>
          <input class="currency" name="system.currency.pp" type="number" value="{{system.currency.pp}}"
            data-dtype="Number" placeholder="0" />
        </label>
        {{/if}}
        <label class="wwn-purse-field" title="{{localize 'WWN.items.PersonalTreasureHint'}}">
          <span class="wwn-purse-label">{{localize "WWN.items.PersonalTreasure"}}</span>
          <input class="currency" name="system.personalTreasure" type="number" value="{{system.personalTreasure}}"
            data-dtype="Number" disabled />
        </label>
        <label class="wwn-purse-field" title="{{localize 'WWN.items.bank.long'}}">
          <span class="wwn-purse-label">{{localize "WWN.items.bank.short"}}</span>
          <input class="currency" name="system.currency.bank" type="number" value="{{system.currency.bank}}"
            data-dtype="Number" placeholder="0" />
        </label>
        <label class="wwn-purse-field" title="{{localize 'WWN.items.total.long'}}">
          <span class="wwn-purse-label">{{localize "WWN.items.total.short"}}</span>
          <input class="currency" name="system.currency.total" type="number" value="{{system.currency.total}}"
            data-dtype="Number" disabled />
        </label>
        <label class="wwn-purse-field" title="{{localize 'WWN.items.TreasureSP'}}">
          <span class="wwn-purse-label">{{localize "WWN.items.Treasure"}}</span>
          <input class="currency" name="system.treasure" type="number" value="{{system.treasure}}"
            data-dtype="Number" disabled />
        </label>
      </div>
    </div>

    {{#> wwnCollapsibleSection sectionId="inventory.weapons" label=(localize "WWN.items.Weapons")
      count=weapons.length collapsed=(lookup @root.collapsed "inventory.weapons") searchType="weapon"
      createType="weapon"}}
    <div class="item-titles item-col-header wwn-col-header flexrow">
      <div class="item-name">{{localize "WWN.Sheet.Name"}}</div>
      <div class="icon-row">{{localize "WWN.items.enterTrait"}}</div>
      {{#if useTrauma}}
      <div class="field-short" data-tooltip="{{localize 'WWN.items.TraumaDieHint'}}">
        {{localize "WWN.items.TraumaDie"}}
      </div>
      {{/if}}
      <div class="field-short" data-tooltip="{{localize 'WWN.items.Charges'}}"><i class="fas fa-magic"></i></div>
      <div class="field-short" data-tooltip="{{localize 'WWN.items.Quantity'}}"><i class="fas fa-hashtag"></i></div>
      <div class="field-short" data-tooltip="{{localize 'WWN.items.Weight'}}">
        <i class="fas fa-weight-hanging"></i>
      </div>
      <div class="item-controls"></div>
    </div>
    <ol class="item-list">
      {{#each weapons as |item|}}
      {{#unless item.system.containerId}}
      <li class="item-entry">
        <div class="item flexrow" data-item-id="{{item.id}}">
          <div class="item-name item-rollable flexrow" data-action="showItem">
            <img class="item-image" src="{{item.img}}" alt="" data-action="rollItem" />
            <h4 title="{{item.name}}">
                {{item.name~}}
                {{#if item.system.damage}}<span class="greyrow">({{item.system.damage}})</span>{{/if}}
              </h4>
          </div>
          <div class="icon-row flexrow">
            {{#each item.system.tags as |tag|}}
            {{#if (getTagIcon tag)}}
            <img title="{{getTagDesc tag}}" src="{{getTagIcon tag}}" />
            {{else}}
            <span title="{{tag}}">{{tag}}{{#unless @last}},{{/unless}}</span>
            {{/if}}
            {{/each}}
          </div>
          {{#if @root.useTrauma}}
          <div class="field-short" data-tooltip="{{localize 'WWN.items.TraumaDieHint'}}">
            {{#if item.system.trauma.die}}{{item.system.trauma.die}}/x{{item.system.trauma.rating}}{{/if}}
          </div>
          {{/if}}
          <div class="field-short charges">
            {{#if (eq item.system.ammoMode "magazine")}}
            <input value="{{item.system.charges.value}}" type="number" disabled class="charges-input" />
            <div class="charges-reload-overlay">
              <a class="item-control" data-action="reloadWeapon" title="{{localize 'WWN.items.ReloadWeapon'}}">
                <i class="fas fa-sync-alt"></i>
              </a>
            </div>
            {{else}}
            <input value="{{item.system.charges.value}}" type="number" data-item-field="system.charges.value" />
            {{/if}}
          </div>
          <div class="field-short quantity">
            <input value="{{item.system.quantity}}" type="number" data-item-field="system.quantity" />
          </div>
          <div class="field-short">
            <input value="{{item.system.weight}}" type="number" readonly />
          </div>
          <div class="item-controls">
            {{#if @root.owner}}
            <a class="item-control{{#unless item.system.equipped}} item-unequipped{{/unless}}"
              data-action="toggleEquipped" title="{{localize 'WWN.items.Equip'}}">
              <i class="fas fa-tshirt"></i>
            </a>
            <a class="item-control{{#unless item.system.stowed}} item-unstowed{{/unless}}"
              data-action="toggleStowed" title="{{localize 'WWN.items.stowed'}}">
              <i class="fas fa-archive"></i>
            </a>
            {{> wwnItemControls favoritable=@root.favoritesEnabled favorited=item.favorited}}
            {{/if}}
          </div>
        </div>
      </li>
      {{/unless}}
      {{/each}}
    </ol>
    {{/wwnCollapsibleSection}}

    {{#> wwnCollapsibleSection sectionId="inventory.armor" label=(localize "WWN.items.Armors")
      count=armors.length collapsed=(lookup @root.collapsed "inventory.armor") searchType="armor"
      createType="armor"}}
    <div class="item-titles item-col-header wwn-col-header flexrow">
      <div class="item-name"></div>
      <div class="field-short">{{localize "WWN.Armor.AC"}}</div>
      <div class="field-short" title="{{localize 'WWN.items.ArmorBonusHint'}}">{{localize "WWN.items.ArmorBonus"}}</div>
      {{#if useTrauma}}
      <div class="field-short" title="{{localize 'WWN.items.TraumaModHint'}}">{{localize "WWN.items.TraumaMod"}}</div>
      {{/if}}
      <div class="field-short" title="{{localize 'WWN.items.Weight'}}"><i class="fas fa-weight-hanging"></i></div>
      <div class="item-controls"></div>
    </div>
    <ol class="item-list">
      {{#each armors as |item|}}
      {{#unless item.system.containerId}}
      <li class="item-entry">
        <div class="item flexrow" data-item-id="{{item.id}}">
          <div class="item-name item-rollable flexrow" data-action="showItem">
            <img class="item-image" src="{{item.img}}" alt="" />
            <h4 title="{{item.name}}">{{item.name~}}</h4>
          </div>
          <div class="field-short">{{item.system.acValue}}</div>
          <div class="field-short">{{item.system.modValue}}</div>
          {{#if @root.useTrauma}}
          <div class="field-short" data-tooltip="{{localize 'WWN.items.TraumaModHint'}}">
            {{item.system.traumaTargetValue}}
          </div>
          {{/if}}
          <div class="field-short">{{item.system.weight}}</div>
          <div class="item-controls">
            {{#if @root.owner}}
            <a class="item-control{{#unless item.system.equipped}} item-unequipped{{/unless}}"
              data-action="toggleEquipped" title="{{localize 'WWN.items.Equip'}}">
              <i class="fas fa-tshirt"></i>
            </a>
            <a class="item-control{{#unless item.system.stowed}} item-unstowed{{/unless}}"
              data-action="toggleStowed" title="{{localize 'WWN.items.stowed'}}">
              <i class="fas fa-archive"></i>
            </a>
            {{> wwnItemControls favoritable=@root.favoritesEnabled favorited=item.favorited}}
            {{/if}}
          </div>
        </div>
      </li>
      {{/unless}}
      {{/each}}
    </ol>
    {{/wwnCollapsibleSection}}

    {{#> wwnCollapsibleSection sectionId="inventory.consumables" label=(localize "WWN.category.consumables")
      collapsed=(lookup @root.collapsed "inventory.consumables") createType="item" createSubType="consumable"}}
    <div class="item-titles item-col-header wwn-col-header flexrow">
      <div class="item-name"></div>
      <div class="field-short" title="{{localize 'WWN.items.Charges'}}"><i class="fas fa-magic"></i></div>
      <div class="field-short" title="{{localize 'WWN.items.Weight'}}"><i class="fas fa-weight-hanging"></i></div>
      <div class="item-controls"></div>
    </div>
    <ol class="item-list">
      {{#each gear as |item|}}
      {{#if (evalOr item.system.charges.value item.system.charges.max)}}
      {{#unless item.system.containerId}}
      <li class="item-entry">
        <div class="item flexrow" data-item-id="{{item.id}}">
          <div class="item-name item-rollable flexrow" data-action="showItem">
            <img class="item-image" src="{{item.img}}" alt="" />
            <h4 title="{{item.name}}">{{item.name~}}</h4>
          </div>
          <div class="field-short charges">
            <input value="{{item.system.charges.value}}" type="number" data-item-field="system.charges.value" />
          </div>
          <div class="field-short">
            <input value="{{item.system.weight}}" type="number" readonly />
          </div>
          <div class="item-controls">
            {{#if @root.owner}}
            <a class="item-control{{#unless item.system.equipped}} item-unequipped{{/unless}}"
              data-action="toggleEquipped" title="{{localize 'WWN.items.Equip'}}">
              <i class="fas fa-tshirt"></i>
            </a>
            <a class="item-control{{#unless item.system.stowed}} item-unstowed{{/unless}}"
              data-action="toggleStowed" title="{{localize 'WWN.items.stowed'}}">
              <i class="fas fa-archive"></i>
            </a>
            {{> wwnItemControls favoritable=@root.favoritesEnabled favorited=item.favorited}}
            {{/if}}
          </div>
        </div>
      </li>
      {{/unless}}
      {{/if}}
      {{/each}}
    </ol>
    {{/wwnCollapsibleSection}}

    {{#> wwnCollapsibleSection sectionId="inventory.misc" label=(localize "WWN.items.Misc")
      collapsed=(lookup @root.collapsed "inventory.misc") searchType="item" createType="item"}}
    <div class="item-titles item-col-header wwn-col-header flexrow">
      <div class="item-name"></div>
      <div class="field-short" title="{{localize 'WWN.items.Quantity'}}"><i class="fas fa-hashtag"></i></div>
      <div class="field-short" title="{{localize 'WWN.items.Weight'}}"><i class="fas fa-weight-hanging"></i></div>
      <div class="item-controls"></div>
    </div>
    <ol class="item-list">
      {{#each gear as |item|}}
      {{#unless (evalOr (evalOr item.system.charges.value item.system.personal) item.system.treasure)}}
      {{#unless item.system.containerId}}
      <li class="item-entry">
        <div class="item flexrow" data-item-id="{{item.id}}">
          <div class="item-name item-rollable flexrow" data-action="showItem">
            <img class="item-image" src="{{item.img}}" alt="" />
            {{#if item.system.container.isContainer}}
            <a class="container-arrow" data-action="toggleContainer">
              <i class="fas {{#if item.system.container.isOpen}}fa-caret-down{{else}}fa-caret-right{{/if}}"
                title="{{localize 'WWN.ToggleContents'}}"></i>
            </a>
            {{/if}}
            <h4 title="{{item.name}}">{{item.name~}}</h4>
          </div>
          <div class="field-short quantity">
            <input value="{{item.system.quantity}}" type="number" placeholder="0" data-item-field="system.quantity" />
          </div>
          <div class="field-short">
            <input value="{{item.system.weight}}" type="number" readonly />
          </div>
          <div class="item-controls">
            {{#if @root.owner}}
            <a class="item-control{{#unless item.system.equipped}} item-unequipped{{/unless}}"
              data-action="toggleEquipped" title="{{localize 'WWN.items.Equip'}}">
              <i class="fas fa-tshirt"></i>
            </a>
            <a class="item-control{{#unless item.system.stowed}} item-unstowed{{/unless}}"
              data-action="toggleStowed" title="{{localize 'WWN.items.stowed'}}">
              <i class="fas fa-archive"></i>
            </a>
            {{> wwnItemControls favoritable=@root.favoritesEnabled favorited=item.favorited}}
            {{/if}}
          </div>
        </div>
        {{#if item.system.container.isContainer}}
        <ol class="item-list container-items{{#unless item.system.container.isOpen}} hidden{{/unless}}">
          {{#each @root.weapons as |weapon|}}
          {{#if (eq weapon.system.containerId item.id)}}
          {{> wwnContainerItem item=weapon}}
          {{/if}}
          {{/each}}
          {{#each @root.armors as |armor|}}
          {{#if (eq armor.system.containerId item.id)}}
          {{> wwnContainerItem item=armor}}
          {{/if}}
          {{/each}}
          {{#each @root.gear as |contained|}}
          {{#if (eq contained.system.containerId item.id)}}
          {{> wwnContainerItem item=contained}}
          {{/if}}
          {{/each}}
        </ol>
        {{/if}}
      </li>
      {{/unless}}
      {{/unless}}
      {{/each}}
    </ol>
    {{/wwnCollapsibleSection}}

    {{#> wwnCollapsibleSection sectionId="inventory.personalTreasure" label=(localize "WWN.category.partyShares")
      collapsed=(lookup @root.collapsed "inventory.personalTreasure") createType="item" createSubType="personal"}}
    <div class="item-titles item-col-header wwn-col-header flexrow">
      <div class="item-name"></div>
      <div class="field-long">{{system.treasure}} <i class="fas fa-circle"></i></div>
      <div class="field-short"><i class="fas fa-hashtag"></i></div>
      <div class="field-short" data-tooltip="{{localize 'WWN.items.Weight'}}"><i class="fas fa-weight-hanging"></i></div>
      <div class="item-controls"></div>
    </div>
    <ol class="item-list">
      {{#each gear as |item|}}
      {{#if item.system.personal}}
      {{#unless item.system.containerId}}
      <li class="item-entry">
        <div class="item flexrow" data-item-id="{{item.id}}">
          <div class="item-name item-rollable flexrow" data-action="showItem">
            <img class="item-image" src="{{item.img}}" alt="" />
            <h4 title="{{item.name}}">{{item.name~}}</h4>
          </div>
          <div class="field-long">{{mult item.system.quantity item.system.price}}</div>
          <div class="field-short quantity">
            <input value="{{item.system.quantity}}" type="number" placeholder="0" data-item-field="system.quantity" />
          </div>
          <div class="field-short">{{item.system.weight}}</div>
          <div class="item-controls">
            {{#if @root.owner}}
            {{> wwnItemControls favoritable=@root.favoritesEnabled favorited=item.favorited}}
            {{/if}}
          </div>
        </div>
      </li>
      {{/unless}}
      {{/if}}
      {{/each}}
    </ol>
    {{/wwnCollapsibleSection}}

    {{#> wwnCollapsibleSection sectionId="inventory.treasure" label=(localize "WWN.items.Treasure")
      collapsed=(lookup @root.collapsed "inventory.treasure") createType="item" createSubType="treasure"}}
    <div class="item-titles item-col-header wwn-col-header flexrow">
      <div class="item-name"></div>
      <div class="field-long">{{system.treasure}} <i class="fas fa-circle"></i></div>
      <div class="field-short"><i class="fas fa-hashtag"></i></div>
      <div class="field-short" title="{{localize 'WWN.items.Weight'}}"><i class="fas fa-weight-hanging"></i></div>
      <div class="item-controls"></div>
    </div>
    <ol class="item-list">
      {{#each gear as |item|}}
      {{#if (evalAnd item.system.treasure (nt item.system.personal true))}}
      {{#unless item.system.containerId}}
      <li class="item-entry">
        <div class="item flexrow" data-item-id="{{item.id}}">
          <div class="item-name item-rollable flexrow" data-action="showItem">
            <img class="item-image" src="{{item.img}}" alt="" />
            <h4 title="{{item.name}}">{{item.name~}}</h4>
          </div>
          <div class="field-long">{{mult item.system.quantity item.system.price}}</div>
          <div class="field-short quantity">
            <input value="{{item.system.quantity}}" type="number" placeholder="0" data-item-field="system.quantity" />
          </div>
          <div class="field-short">{{item.system.weight}}</div>
          <div class="item-controls">
            {{#if @root.owner}}
            {{> wwnItemControls favoritable=@root.favoritesEnabled favorited=item.favorited}}
            {{/if}}
          </div>
        </div>
      </li>
      {{/unless}}
      {{/if}}
      {{/each}}
    </ol>
    {{/wwnCollapsibleSection}}

    {{#> wwnCollapsibleSection sectionId="inventory.currency" label=(localize "WWN.Inventory.Currency")
      count=currencies.length collapsed=(lookup @root.collapsed "inventory.currency") createType="currency"}}
    <div class="item-titles item-col-header wwn-col-header flexrow">
      <div class="item-name">{{localize "WWN.Sheet.Name"}}</div>
      <div class="field-short">{{localize "WWN.Currency.Carried"}}</div>
      <div class="field-short">{{localize "WWN.Currency.Banked"}}</div>
      <div class="item-controls"></div>
    </div>
    <ol class="item-list">
      {{#each currencies as |currency|}}
      <li class="item-entry">
        <div class="item flexrow" data-item-id="{{currency.id}}">
          <div class="item-name flexrow" data-action="showItem">
            <img class="item-image" src="{{currency.img}}" alt="" />
            <h4>{{currency.name}}</h4>
            <span class="greyrow">×{{currency.system.multiplier}}</span>
          </div>
          <div class="field-short">
            <input type="number" value="{{currency.system.carried}}" data-item-field="system.carried" />
          </div>
          <div class="field-short">
            <input type="number" value="{{currency.system.banked}}" data-item-field="system.banked" />
          </div>
          <div class="item-controls">
            {{#if @root.owner}}
            {{> wwnItemControls}}
            {{/if}}
          </div>
        </div>
      </li>
      {{/each}}
    </ol>
    {{/wwnCollapsibleSection}}

  </div>
</section>
