{{!-- Faction Tags tab. --}}
<section class="tab {{tab.cssClass}}" data-group="{{tab.group}}" data-tab="{{tab.id}}">
  <div class="wwn-form-stack">
    <div class="wwn-form-panel">
      <div class="wwn-section-header flexrow">
        <span class="wwn-collapsible-label">{{localize "WWN.faction.tags-tab"}}</span>
        <div class="item-controls">
          <a data-action="addTag" title="{{localize 'WWN.faction.add-tag'}}"><i class="fas fa-tags"></i></a>
          <a data-action="addCustomTag" title="{{localize 'WWN.faction.add-tag-custom'}}"><i class="fas fa-plus"></i></a>
        </div>
      </div>
      {{#each system.tags as |tag id|}}
      <div class="wwn-faction-tag" data-idx="{{id}}">
        <div class="wwn-faction-tag-header flexrow">
          <b>{{tag.name}}</b>
          <div class="item-controls">
            <a class="item-control" data-action="deleteTag" title="{{localize 'WWN.faction.remove-tag'}}">
              <i class="fas fa-trash"></i>
            </a>
          </div>
        </div>
        <div>{{tag.desc}}</div>
        <div class="powers-muted">Effect: {{tag.effect}}</div>
      </div>
      {{else}}
      <p class="hint">{{localize "WWN.faction.add-tag"}}</p>
      {{/each}}
    </div>
  </div>
</section>
